<% content_for :title, "Conductor · Overview" %>

<section class="border-b border-border bg-bg-alt">
  <div class="max-w-7xl mx-auto px-4 py-10">
    <div class="grid gap-8 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <span class="inline-flex items-center gap-2 rounded-pill bg-primary-tint px-3 py-1 text-2xs font-semibold uppercase tracking-label text-primary">
          Live Ops
        </span>
        <h1 class="mt-4 font-display text-4xl text-ink tracking-display sm:text-5xl">Monitor the rails stack at a glance.</h1>
        <p class="mt-3 max-w-2xl text-base text-muted">
          Track VM health, backup status, and app deployments in one place. Keep everything calm, clean, and fast.
        </p>
        <div class="mt-6 grid gap-4 sm:grid-cols-4">
          <%= link_to servers_path, class: "rounded-large border border-border bg-surface p-4 shadow-soft hover:border-border-strong transition-colors" do %>
            <div class="text-2xs font-semibold uppercase tracking-label text-muted">Servers</div>
            <div class="mt-2 font-mono font-display text-2xl text-ink tracking-display"><%= @stats[:servers_count] %></div>
            <div class="mt-1 text-2xs text-muted">
              <% if @stats[:servers_degraded] > 0 %>
                <%= @stats[:servers_degraded] %> degraded · <%= @stats[:servers_online] %> online
              <% else %>
                <%= @stats[:servers_online] %> online
              <% end %>
            </div>
          <% end %>
          <%= link_to apps_path, class: "rounded-large border border-border bg-surface p-4 shadow-soft hover:border-border-strong transition-colors" do %>
            <div class="text-2xs font-semibold uppercase tracking-label text-muted">Apps</div>
            <div class="mt-2 font-mono font-display text-2xl text-ink tracking-display"><%= @stats[:apps_count] %></div>
            <div class="mt-1 text-2xs text-muted"><%= @stats[:apps_running] %> running</div>
          <% end %>
          <%= link_to backups_path, class: "rounded-large border border-border bg-surface p-4 shadow-soft hover:border-border-strong transition-colors" do %>
            <div class="text-2xs font-semibold uppercase tracking-label text-muted">Backups</div>
            <div class="mt-2 font-mono font-display text-2xl text-ink tracking-display"><%= @stats[:backups_completed] %></div>
            <div class="mt-1 text-2xs text-muted">completed</div>
          <% end %>
          <%= link_to credentials_path, class: "rounded-large border border-border bg-surface p-4 shadow-soft hover:border-border-strong transition-colors" do %>
            <div class="text-2xs font-semibold uppercase tracking-label text-muted">Credentials</div>
            <div class="mt-2 font-mono font-display text-2xl text-ink tracking-display"><%= @stats[:credentials_count] %></div>
            <div class="mt-1 text-2xs text-muted"><%= @stats[:credentials_active] %> active</div>
          <% end %>
        </div>
      </div>
      <div class="rounded-large border border-border bg-surface p-6 shadow-soft">
        <h2 class="text-2xs font-semibold uppercase tracking-label text-muted">Quick Actions</h2>
        <ul class="mt-4 space-y-3 text-sm">
          <li>
            <%= link_to new_server_path, class: "flex items-center gap-3 text-body hover:text-ink" do %>
              <span class="h-2 w-2 rounded-pill bg-primary-sage"></span>
              Add new server
            <% end %>
          </li>
          <li>
            <%= link_to new_app_path, class: "flex items-center gap-3 text-body hover:text-ink" do %>
              <span class="h-2 w-2 rounded-pill bg-primary-sage"></span>
              Register an app
            <% end %>
          </li>
          <li>
            <%= link_to new_credential_path, class: "flex items-center gap-3 text-body hover:text-ink" do %>
              <span class="h-2 w-2 rounded-pill bg-primary-sage"></span>
              Add API credential
            <% end %>
          </li>
        </ul>
        <div class="mt-6 rounded-card border border-dashed border-border bg-fill p-4 text-2xs text-muted">
          <div class="font-semibold uppercase tracking-label text-body">Tip</div>
          <span class="mt-1 block">Keep Caddy + Kamal config snapshots next to R2 backups for audit trails.</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="max-w-7xl mx-auto px-4 py-10 space-y-10">
  <%# Container Status Overview %>
  <% if @apps.any? %>
    <%= render "dashboard/kamal_overview" %>
  <% end %>

  <%# Issues Section - What needs attention %>
  <% if @issues.any? %>
    <div class="rounded-large border border-danger/30 bg-danger-tint p-6 shadow-soft">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="h-10 w-10 rounded-pill bg-danger/10 flex items-center justify-center">
            <svg class="h-5 w-5 text-danger" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          </div>
          <div>
            <h2 class="font-display text-xl text-danger-deep">Attention Required</h2>
            <p class="text-sm text-danger"><%= @issues.count %> issue<%= @issues.count == 1 ? "" : "s" %> need<%= @issues.count == 1 ? "s" : "" %> your attention</p>
          </div>
        </div>
      </div>
      <div class="mt-4 space-y-2">
        <% @issues.first(5).each do |issue| %>
          <div class="flex items-center justify-between rounded-card bg-surface px-4 py-3 border <%= issue[:severity] == 'critical' ? 'border-danger/30' : issue[:severity] == 'warning' ? 'border-warning/40' : 'border-border' %>">
            <div class="flex items-center gap-3">
              <% if issue[:severity] == "critical" %>
                <span class="h-2 w-2 rounded-pill bg-danger-bright animate-pulse"></span>
              <% elsif issue[:severity] == "warning" %>
                <span class="h-2 w-2 rounded-pill bg-warning-bright"></span>
              <% else %>
                <span class="h-2 w-2 rounded-pill bg-faint"></span>
              <% end %>
              <div>
                <span class="text-sm font-medium text-ink">
                  <% if issue[:type] == "server" %>
                    <%= issue[:resource].name %>
                  <% elsif issue[:type] == "app" %>
                    <%= issue[:resource].name %>
                  <% elsif issue[:type] == "deployment" %>
                    <%= issue[:resource].app.name %> deployment
                  <% elsif issue[:type] == "backup" %>
                    <%= issue[:resource].bucket_name %> backup
                  <% end %>
                </span>
                <span class="text-sm text-muted ml-2"><%= issue[:message] %></span>
              </div>
            </div>
            <% if issue[:type] == "server" %>
              <%= link_to "View", server_path(issue[:resource]), class: "text-2xs font-semibold uppercase tracking-label text-muted hover:text-ink" %>
            <% elsif issue[:type] == "app" %>
              <%= link_to "View", app_path(issue[:resource]), class: "text-2xs font-semibold uppercase tracking-label text-muted hover:text-ink" %>
            <% elsif issue[:type] == "deployment" %>
              <%= link_to "View", deployment_path(issue[:resource]), class: "text-2xs font-semibold uppercase tracking-label text-muted hover:text-ink" %>
            <% elsif issue[:type] == "backup" %>
              <%= link_to "View", backup_path(issue[:resource]), class: "text-2xs font-semibold uppercase tracking-label text-muted hover:text-ink" %>
            <% end %>
          </div>
        <% end %>
        <% if @issues.count > 5 %>
          <p class="text-sm text-danger text-center pt-2">+ <%= @issues.count - 5 %> more issues</p>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="rounded-large border border-primary/30 bg-primary-tint p-6 shadow-soft">
      <div class="flex items-center gap-3">
        <div class="h-10 w-10 rounded-pill bg-primary/10 flex items-center justify-center">
          <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </div>
        <div>
          <h2 class="font-display text-xl text-primary">All Systems Operational</h2>
          <p class="text-sm text-primary-strong">No issues detected across your servers and apps</p>
        </div>
      </div>
    </div>
  <% end %>

  <%# Recent Deployments %>
  <% if @recent_deployments.any? %>
    <div class="rounded-large border border-border bg-surface p-6 shadow-soft">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="font-display text-xl text-ink">Recent Deployments</h2>
          <p class="text-sm text-muted">Latest deployment activity across your apps</p>
        </div>
      </div>
      <div class="mt-4 overflow-x-auto">
        <table class="min-w-full">
          <thead>
            <tr class="text-2xs font-semibold uppercase tracking-label text-muted">
              <th class="pb-2 text-left">App</th>
              <th class="pb-2 text-left">Status</th>
              <th class="pb-2 text-left">Duration</th>
              <th class="pb-2 text-left">When</th>
              <th class="pb-2 text-right">Details</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @recent_deployments.each do |deployment| %>
              <tr>
                <td class="py-2 text-sm font-medium text-ink"><%= deployment.app.name %></td>
                <td class="py-2"><span class="<%= status_badge(deployment.status) %>"><%= deployment.status %></span></td>
                <td class="py-2 font-mono text-sm text-body"><%= deployment.formatted_duration %></td>
                <td class="py-2 text-sm text-muted"><%= time_ago_in_words(deployment.created_at) %> ago</td>
                <td class="py-2 text-right"><%= link_to "View", deployment_path(deployment), class: "text-2xs font-semibold uppercase tracking-label text-muted hover:text-ink" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <% if @servers.any? %>
    <div>
      <div class="flex items-center justify-between">
        <div>
          <h2 class="font-display text-xl text-ink">Server Fleet</h2>
          <p class="text-sm text-muted">Health and resource usage across hosts.</p>
        </div>
        <%= link_to "View all", servers_path, class: "text-2xs font-semibold uppercase tracking-label text-faint hover:text-muted" %>
      </div>
      <div class="mt-4 grid gap-4 lg:grid-cols-3">
        <% @servers.limit(3).each do |server| %>
          <div class="rounded-large border border-border bg-surface p-5 shadow-soft">
            <div class="flex items-center justify-between">
              <div>
                <div class="text-sm font-semibold text-ink"><%= server.name %></div>
                <div class="text-2xs text-muted"><%= server.region || server.provider || "—" %></div>
              </div>
              <span class="<%= status_badge(server.status) %>"><%= server.status %></span>
            </div>
            <div class="mt-4 grid grid-cols-2 gap-3">
              <div class="rounded-card bg-fill p-3">
                <div class="text-2xs uppercase tracking-label text-faint">CPU</div>
                <div class="mt-1 font-mono text-sm font-semibold text-ink"><%= server.cpu_display %></div>
              </div>
              <div class="rounded-card bg-fill p-3">
                <div class="text-2xs uppercase tracking-label text-faint">Memory</div>
                <div class="mt-1 font-mono text-sm font-semibold text-ink"><%= server.formatted_memory %></div>
              </div>
              <div class="rounded-card bg-fill p-3">
                <div class="text-2xs uppercase tracking-label text-faint">Disk</div>
                <div class="mt-1 font-mono text-sm font-semibold text-ink"><%= server.disk_display %></div>
              </div>
              <div class="rounded-card bg-fill p-3">
                <div class="text-2xs uppercase tracking-label text-faint">Uptime</div>
                <div class="mt-1 font-mono text-sm font-semibold text-ink"><%= server.formatted_uptime %></div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="grid gap-6 lg:grid-cols-2">
    <% if @backups.any? %>
      <div class="rounded-large border border-border bg-surface p-6 shadow-soft">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="font-display text-xl text-ink">Recent Backups</h2>
            <p class="text-sm text-muted">Latest backup activity.</p>
          </div>
          <%= link_to "View all", backups_path, class: "text-2xs font-semibold uppercase tracking-label text-faint hover:text-muted" %>
        </div>
        <div class="mt-4 space-y-3">
          <% @backups.limit(4).each do |backup| %>
            <div class="flex items-center justify-between rounded-card border border-border bg-bg-alt px-4 py-3">
              <div>
                <div class="text-sm font-semibold text-ink"><%= backup.bucket_name %></div>
                <div class="text-2xs text-muted">Retention <%= backup.retention_display %> · Size <%= backup.formatted_size %></div>
              </div>
              <div class="flex items-center gap-3">
                <div class="text-2xs text-muted"><%= backup.time_ago %></div>
                <span class="<%= status_badge(backup.status) %>"><%= backup.status %></span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @apps.any? %>
      <div class="rounded-large border border-border bg-surface p-6 shadow-soft">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="font-display text-xl text-ink">Deployed Apps</h2>
            <p class="text-sm text-muted">Rails applications across your fleet.</p>
          </div>
          <%= link_to "View all", apps_path, class: "text-2xs font-semibold uppercase tracking-label text-faint hover:text-muted" %>
        </div>
        <div class="mt-4 space-y-3">
          <% @apps.limit(4).each do |app| %>
            <div class="rounded-card border border-border bg-bg-alt px-4 py-3">
              <div class="flex items-center justify-between">
                <div>
                  <div class="text-sm font-semibold text-ink"><%= app.name %></div>
                  <div class="text-2xs text-muted"><%= app.server_name %> · <%= app.domain || "No domain" %></div>
                </div>
                <span class="<%= status_badge(app.status) %>"><%= app.status %></span>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <% if @servers.empty? && @backups.empty? && @apps.empty? %>
    <div class="rounded-large border border-dashed border-border-strong bg-fill p-12 text-center">
      <div class="font-display text-2xl text-ink">Get started with Conductor</div>
      <p class="mt-2 text-sm text-muted">Add your first server, app, or credential to begin monitoring.</p>
      <div class="mt-6 flex items-center justify-center gap-4">
        <%= link_to "Add Server", new_server_path, class: "inline-flex items-center rounded-control bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-strong" %>
        <%= link_to "Add App", new_app_path, class: "inline-flex items-center rounded-control border border-border bg-surface px-4 py-2 text-sm font-medium text-body hover:bg-fill" %>
      </div>
    </div>
  <% end %>
</section>
