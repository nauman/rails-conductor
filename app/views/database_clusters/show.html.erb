<section class="mx-auto max-w-3xl">
  <%= link_to "← Clusters", database_clusters_path, class: "text-sm text-muted hover:text-ink" %>
  <div class="mt-2 flex items-center justify-between">
    <div>
      <h1 class="font-display text-xl text-ink"><%= @cluster.name %></h1>
      <p class="text-sm text-muted"><%= @cluster.server&.name %> · <%= @cluster.container_name %> · admin <%= @cluster.admin_username %> · :<%= @cluster.port %></p>
    </div>
  </div>

  <div class="mt-6 rounded-large border border-border bg-surface p-5 shadow-soft">
    <h2 class="text-sm font-semibold text-ink">Create a database</h2>
    <%= form_with url: database_cluster_databases_path(@cluster), method: :post, scope: :database, class: "mt-3 flex flex-wrap items-end gap-3" do |f| %>
      <div class="flex-1 min-w-48">
        <%= f.label :name, "Database name", class: "block text-xs font-medium text-body" %>
        <%= f.text_field :name, required: true, placeholder: "myapp_production",
              class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary-tint0 focus:ring-primary-tint0 sm:text-sm font-mono" %>
        <p class="mt-1 text-xs text-faint">Role + database are created; a password is generated.</p>
      </div>
      <%= f.submit "Create", class: "cursor-pointer rounded-md bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary" %>
    <% end %>
  </div>

  <div class="mt-6 rounded-large border border-border bg-surface shadow-soft">
    <div class="border-b border-border px-5 py-3 text-sm font-semibold text-body">Databases</div>
    <% if @databases.any? %>
      <ul class="divide-y divide-border">
        <% @databases.each do |db| %>
          <li class="flex items-center justify-between px-5 py-3">
            <div>
              <div class="font-mono text-sm text-ink"><%= db.name %></div>
              <div class="text-xs text-muted">role <%= db.username %><%= " · #{db.app.name}" if db.app %></div>
            </div>
            <div class="flex items-center gap-3">
              <%= rui_badge(text: db.status, color: db.status == "active" ? :success : db.status == "error" ? :danger : :warning, size: :sm) %>
              <%= rui_button_to("Drop", database_path(db), method: :delete, variant: :link, color: :danger, size: :sm,
                    data: { turbo_confirm: "Drop database #{db.name} and its role? This cannot be undone." }) %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="px-5 py-6 text-center text-sm text-muted">No databases on this cluster yet.</div>
    <% end %>
  </div>
</section>
