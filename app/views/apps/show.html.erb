<% content_for :title, "#{@app.name} · Conductor" %>

<section class="max-w-7xl mx-auto px-4 py-10">
  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="font-display text-2xl text-ink tracking-display dark:text-white"><%= @app.name %></h1>
        <% if @app.status == "running" && @app.status_check_error.present? %>
          <%= rui_badge(text: "Running · needs attention", color: :warning) %>
        <% else %>
          <%= rui_badge(text: @app.status, color: @app.status == "running" ? :success : @app.status == "failed" ? :danger : :slate) %>
        <% end %>
      </div>
      <p class="mt-1 text-sm text-muted dark:text-faint">
        <% if @app.domain.present? %>
          <%= rui_link(@app.domain, url: @app.url, external: true) %> ·
        <% end %>
        <code class="text-xs bg-fill-strong dark:bg-fill px-1.5 py-0.5 rounded"><%= @app.slug %></code>
        <% if @app.deployed_at.present? %>
          · Deployed <%= time_ago_in_words(@app.deployed_at) %> ago
        <% end %>
      </p>
      <% if @app.notes.present? %>
        <p class="mt-2 max-w-2xl text-sm text-body dark:text-faint whitespace-pre-line"><%= @app.notes %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-2">
      <% if @app.deployable? %>
        <% if @app.deployments.in_progress.any? %>
          <%= rui_badge(text: "Deploying...", color: :warning, size: :lg) %>
        <% else %>
          <%= rui_button_to("Deploy", deploy_app_path(@app), method: :post, variant: :solid, color: :success) %>
        <% end %>
      <% end %>
      <% if @app.status == "running" %>
        <%= rui_button_to("Restart", restart_app_path(@app), method: :post, variant: :outline, color: :slate) %>
        <%= rui_button_to("Stop", stop_app_path(@app), method: :post, variant: :outline, color: :slate, data: { turbo_confirm: "Stop this app?" }) %>
      <% end %>
      <%= rui_button("Edit", url: edit_app_path(@app), variant: :outline, color: :slate) %>
      <%= rui_button("Back", url: apps_path, variant: :outline, color: :slate) %>
    </div>
  </div>

  <% if @app.native? %>
    <%# Service Status (Native) %>
    <div class="mt-8 rounded-large border border-border dark:border-border bg-surface dark:bg-body p-6 shadow-soft">
      <h2 class="text-sm font-semibold text-ink dark:text-white">Service Status</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-4">
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Status</dt>
          <dd class="mt-1 flex items-center gap-2">
            <% if @app.status == "running" %>
              <span class="h-2 w-2 rounded-full bg-primary-tint0"></span>
              <span class="text-sm font-medium text-primary dark:text-primary-sage">Running</span>
            <% elsif @app.status == "failed" %>
              <span class="h-2 w-2 rounded-full bg-danger-tint0"></span>
              <span class="text-sm font-medium text-danger-deep dark:text-danger-bright">Failed</span>
            <% else %>
              <span class="h-2 w-2 rounded-full bg-faint"></span>
              <span class="text-sm font-medium text-body dark:text-faint"><%= @app.status.capitalize %></span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Service Name</dt>
          <dd class="mt-1 text-sm text-ink dark:text-white font-mono"><%= @app.service_name %></dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Deploy Method</dt>
          <dd class="mt-1 text-sm text-ink dark:text-white">Native (Puma + systemd)</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">App Directory</dt>
          <dd class="mt-1 text-sm text-ink dark:text-white font-mono text-xs truncate"><%= @app.app_dir %></dd>
        </div>
      </div>
    </div>
  <% else %>
    <%# Container Status (Docker) %>
    <div class="mt-8 rounded-large border border-border dark:border-border bg-surface dark:bg-body p-6 shadow-soft">
      <div class="flex items-center justify-between">
        <h2 class="text-sm font-semibold text-ink dark:text-white">Container Status</h2>
        <% if @app.can_sync_status? %>
          <%= rui_button_to("Sync Status", sync_status_app_path(@app), method: :post, variant: :outline, size: :sm, color: :slate) %>
        <% end %>
      </div>
      <div class="mt-4 grid gap-4 sm:grid-cols-4">
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Container</dt>
          <dd class="mt-1 flex items-center gap-2">
            <% case @app.container_status %>
            <% when "running" %>
              <span class="h-2 w-2 rounded-full bg-primary-tint0"></span>
              <span class="text-sm font-medium text-primary dark:text-primary-sage">Running</span>
            <% when "exited", "dead" %>
              <span class="h-2 w-2 rounded-full bg-danger-tint0"></span>
              <span class="text-sm font-medium text-danger-deep dark:text-danger-bright"><%= @app.container_status.capitalize %></span>
            <% when "restarting" %>
              <span class="h-2 w-2 rounded-full bg-warning-tint0 animate-pulse"></span>
              <span class="text-sm font-medium text-warning dark:text-warning-bright">Restarting</span>
            <% else %>
              <span class="h-2 w-2 rounded-full bg-faint"></span>
              <span class="text-sm font-medium text-body dark:text-faint">Unknown</span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Started At</dt>
          <dd class="mt-1 text-sm text-ink dark:text-white">
            <%= @app.container_started_at.present? ? time_ago_in_words(@app.container_started_at) + " ago" : "—" %>
          </dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Last Checked</dt>
          <dd class="mt-1 text-sm text-ink dark:text-white">
            <%= @app.last_status_check_at.present? ? time_ago_in_words(@app.last_status_check_at) + " ago" : "Never" %>
          </dd>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Container Name</dt>
          <dd class="mt-1 text-sm text-ink dark:text-white font-mono"><%= @app.container_name %></dd>
        </div>
      </div>
      <% if @app.status_check_error.present? %>
        <%= rui_alert(type: :danger, class: "mt-4") do %>
          <span class="font-medium">Error:</span> <%= @app.status_check_error %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# Stats Grid %>
  <div class="mt-8 grid gap-6 lg:grid-cols-4">
    <div class="rounded-large border border-border dark:border-border bg-surface dark:bg-body p-5 shadow-soft">
      <div class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Server</div>
      <div class="mt-2 font-display text-xl text-ink dark:text-white"><%= @app.server_name %></div>
    </div>
    <div class="rounded-large border border-border dark:border-border bg-surface dark:bg-body p-5 shadow-soft">
      <div class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Port</div>
      <div class="mt-2 font-display text-xl text-ink dark:text-white"><%= @app.port || "—" %></div>
    </div>
    <div class="rounded-large border border-border dark:border-border bg-surface dark:bg-body p-5 shadow-soft">
      <div class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Branch</div>
      <div class="mt-2 font-display text-xl text-ink dark:text-white"><%= @app.branch || "—" %></div>
    </div>
    <div class="rounded-large border border-border dark:border-border bg-surface dark:bg-body p-5 shadow-soft">
      <div class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">SSL</div>
      <div class="mt-2 font-display text-xl text-ink dark:text-white"><%= @app.ssl_enabled? ? "Enabled" : "Disabled" %></div>
    </div>
  </div>

  <%# Repository Info %>
  <div class="mt-8 rounded-large border border-border dark:border-border bg-surface dark:bg-body p-6 shadow-soft">
    <h2 class="text-sm font-semibold text-ink dark:text-white">Repository</h2>
    <% if @app.repository_url.present? %>
      <div class="mt-3 grid gap-4 sm:grid-cols-3 text-sm">
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">URL</dt>
          <dd class="mt-1 text-ink dark:text-white truncate"><%= @app.repository_url %></dd>
        </div>
        <% if @app.docker? %>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Dockerfile</dt>
            <dd class="mt-1 text-ink dark:text-white"><%= @app.dockerfile_path %></dd>
          </div>
        <% end %>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Health Check</dt>
          <dd class="mt-1 text-ink dark:text-white"><%= @app.health_check_path || "—" %></dd>
        </div>
      </div>
    <% else %>
      <p class="mt-2 text-sm text-muted dark:text-faint">No repository configured. <%= rui_link("Edit app", url: edit_app_path(@app)) %> to add one.</p>
    <% end %>

    <%# Deploy key (for cloning a private repo) %>
    <% if @app.repository_url.present? %>
      <div class="mt-4 pt-4 border-t border-border dark:border-border">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Deploy Key</h3>
            <p class="mt-1 text-xs text-muted dark:text-faint">Read-only key Conductor uses to clone a private repo. Add the public key to the repo's GitHub deploy keys.</p>
          </div>
          <%= button_to (@app.deploy_key ? "Regenerate" : "Generate"), generate_deploy_key_app_path(@app), method: :post,
                data: { turbo_confirm: @app.deploy_key ? "Regenerate the deploy key? You'll need to re-add the new public key on GitHub." : nil },
                class: "rounded-lg border border-border dark:border-border-strong bg-surface dark:bg-fill px-3 py-1.5 text-xs font-medium text-body dark:text-body hover:bg-fill dark:hover:bg-fill-strong" %>
        </div>
        <% if @app.deploy_key %>
          <div class="mt-3">
            <code class="block w-full overflow-x-auto rounded-lg bg-ink text-surface px-3 py-2 text-xs"><%= @app.deploy_key.public_key %></code>
            <p class="mt-1 text-xs text-faint">Add at <span class="font-mono">github.com/&lt;owner&gt;/&lt;repo&gt;/settings/keys/new</span> (read-only). Fingerprint: <%= @app.deploy_key.fingerprint %></p>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Auto-deploy on push %>
  <div class="mt-8 rounded-large border border-border bg-surface p-6 shadow-soft">
    <div class="flex items-center justify-between gap-4">
      <div>
        <h2 class="text-sm font-semibold text-ink">Auto-deploy on push</h2>
        <p class="mt-1 text-sm text-muted">Deploy automatically when GitHub pushes to <code class="text-xs bg-fill-strong px-1.5 py-0.5 rounded"><%= @app.branch.presence || "main" %></code>.</p>
      </div>
      <div class="flex items-center gap-3">
        <% if @app.auto_deploy? %>
          <span class="inline-flex items-center rounded-pill bg-primary-tint px-2.5 py-1 text-2xs font-semibold uppercase tracking-label text-primary ring-1 ring-inset ring-primary/20">On</span>
        <% else %>
          <span class="inline-flex items-center rounded-pill bg-fill px-2.5 py-1 text-2xs font-semibold uppercase tracking-label text-muted ring-1 ring-inset ring-border-strong">Off</span>
        <% end %>
        <%= button_to (@app.auto_deploy? ? "Disable" : "Enable"), toggle_auto_deploy_app_path(@app), method: :patch,
              class: "rounded-control border border-border-strong px-3 py-1.5 text-sm font-medium text-body hover:bg-fill" %>
      </div>
    </div>
    <% if @app.auto_deploy? %>
      <div class="mt-4 space-y-3 border-t border-border pt-4">
        <p class="text-2xs font-semibold uppercase tracking-label text-muted">GitHub webhook (Settings → Webhooks → Add webhook)</p>
        <div>
          <div class="text-2xs uppercase tracking-label text-faint">Payload URL</div>
          <code class="mt-1 block font-mono text-xs bg-fill rounded-card px-3 py-2 break-all"><%= request.base_url %><%= @app.webhook_path %></code>
        </div>
        <div>
          <div class="text-2xs uppercase tracking-label text-faint">Secret</div>
          <code class="mt-1 block font-mono text-xs bg-fill rounded-card px-3 py-2 break-all"><%= @app.webhook_secret %></code>
        </div>
        <p class="text-2xs text-faint">Content type: <code>application/json</code> · Events: just the push event. Conductor verifies the signature and deploys only on the <code><%= @app.branch.presence || "main" %></code> branch.</p>
      </div>
    <% end %>
  </div>

  <%# Database %>
  <div class="mt-8 rounded-large border border-border dark:border-border bg-surface dark:bg-body p-6 shadow-soft">
    <div class="flex items-center justify-between">
      <h2 class="text-sm font-semibold text-ink dark:text-white">Database</h2>
      <% if @app.databases.none? %>
        <%= rui_button_to("Provision database", provision_database_app_path(@app), method: :post, variant: :solid, color: :primary, size: :sm) %>
      <% end %>
    </div>
    <% if @app.databases.any? %>
      <% @app.databases.each do |db| %>
        <div class="mt-4 rounded-lg bg-fill dark:bg-ink p-4">
          <div class="flex items-center justify-between">
            <div class="font-mono text-sm text-ink dark:text-white"><%= db.name %></div>
            <%= rui_badge(text: db.status, color: db.status == "active" ? :success : db.status == "error" ? :danger : :warning, size: :sm) %>
          </div>
          <dl class="mt-3 grid gap-2 text-xs sm:grid-cols-2">
            <div><dt class="text-faint">Host</dt><dd class="font-mono text-body dark:text-body"><%= db.database_cluster.container_name %>:<%= db.database_cluster.port %></dd></div>
            <div><dt class="text-faint">Role</dt><dd class="font-mono text-body dark:text-body"><%= db.username %></dd></div>
            <div class="sm:col-span-2"><dt class="text-faint">DATABASE_URL</dt><dd class="font-mono text-body dark:text-body break-all select-all"><%= db.database_url %></dd></div>
          </dl>
          <p class="mt-2 text-xs text-faint">Add this to the app's deploy config / env.</p>
        </div>
      <% end %>
    <% else %>
      <p class="mt-2 text-sm text-muted dark:text-faint">No database yet. Provision one on a registered <%= rui_link("cluster", url: database_clusters_path) %> — role, database, and password are created automatically.</p>
    <% end %>
  </div>

  <%# Environment Variables %>
  <div id="env-vars" class="mt-8 rounded-large border border-border dark:border-border bg-surface dark:bg-body shadow-soft overflow-hidden">
    <div class="p-4 border-b border-border dark:border-border bg-fill dark:bg-fill flex items-center justify-between">
      <h3 class="text-sm font-semibold text-ink dark:text-white">Environment Variables</h3>
      <%= rui_badge(text: pluralize(@env_variables.count, "variable"), color: :slate, size: :sm) %>
    </div>

    <%# Add new variable form %>
    <div class="p-4 border-b border-border dark:border-border">
      <%= form_with model: [@app, EnvVariable.new], class: "flex items-end gap-3" do |f| %>
        <div class="w-40">
          <label class="block text-xs font-medium text-body dark:text-faint mb-1">Key</label>
          <%= f.text_field :key, class: "block w-full rounded-lg border-border-strong dark:border-border-strong dark:bg-fill dark:text-white shadow-soft focus:border-primary focus:ring-primary text-sm font-mono", placeholder: "DATABASE_URL" %>
        </div>
        <div class="flex-1">
          <label class="block text-xs font-medium text-body dark:text-faint mb-1">Value</label>
          <%= f.text_field :value, class: "block w-full rounded-lg border-border-strong dark:border-border-strong dark:bg-fill dark:text-white shadow-soft focus:border-primary focus:ring-primary text-sm font-mono", placeholder: "postgres://..." %>
        </div>
        <div class="flex items-center gap-2">
          <%= f.check_box :secret, class: "rounded border-border-strong dark:border-border-strong text-ink focus:ring-primary" %>
          <%= f.label :secret, "Secret", class: "text-sm text-body dark:text-faint" %>
        </div>
        <%= f.rui_button(color: :primary, size: :sm) %>
      <% end %>
    </div>

    <% if @env_variables.any? %>
      <table class="min-w-full divide-y divide-border dark:divide-border">
        <thead class="bg-fill dark:bg-fill">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Key</th>
            <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Value</th>
            <th class="px-4 py-2 text-right text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border dark:divide-border">
          <% @env_variables.each do |var| %>
            <tr>
              <td class="px-4 py-2 text-sm font-mono text-ink dark:text-white"><%= var.key %></td>
              <td class="px-4 py-2 text-sm font-mono text-body dark:text-faint">
                <% if var.secret? %>
                  <span class="text-faint dark:text-muted">••••••••</span>
                <% else %>
                  <span class="truncate max-w-xs block"><%= var.value %></span>
                <% end %>
              </td>
              <td class="px-4 py-2 text-right">
                <%= rui_button_to("Remove", app_env_variable_path(@app, var), method: :delete, variant: :link, color: :danger, size: :sm, data: { turbo_confirm: "Remove #{var.key}?" }) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-4 text-center text-sm text-muted dark:text-faint">
        No environment variables configured.
      </div>
    <% end %>
  </div>

  <%# Deployment History %>
  <div class="mt-8 rounded-large border border-border dark:border-border bg-surface dark:bg-body shadow-soft overflow-hidden">
    <div class="p-4 border-b border-border dark:border-border bg-fill dark:bg-fill flex items-center justify-between">
      <h3 class="text-sm font-semibold text-ink dark:text-white">Deployment History</h3>
      <% if @app.container_id.present? || @app.native? %>
        <%= rui_button("View Logs", url: logs_app_path(@app), variant: :link, size: :sm, color: :slate) %>
      <% end %>
    </div>

    <% if @deployments.any? %>
      <table class="min-w-full divide-y divide-border dark:divide-border">
        <thead class="bg-fill dark:bg-fill">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Status</th>
            <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Started</th>
            <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Duration</th>
            <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">By</th>
            <th class="px-4 py-2 text-right text-xs font-semibold uppercase tracking-wide text-muted dark:text-faint">Details</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border dark:divide-border">
          <% @deployments.each do |deployment| %>
            <tr>
              <td class="px-4 py-2">
                <%= rui_badge(text: deployment.status, color: deployment.status == "completed" ? :success : deployment.status == "failed" ? :danger : :slate, size: :sm) %>
              </td>
              <td class="px-4 py-2 text-sm text-body dark:text-faint">
                <%= deployment.created_at.strftime("%b %d, %H:%M") %>
              </td>
              <td class="px-4 py-2 text-sm text-body dark:text-faint">
                <%= deployment.formatted_duration %>
              </td>
              <td class="px-4 py-2 text-sm text-body dark:text-faint">
                <%= deployment.user&.email || "System" %>
              </td>
              <td class="px-4 py-2 text-right">
                <%= rui_button("View", url: deployment_path(deployment), variant: :link, size: :sm, color: :slate) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-4 text-center text-sm text-muted dark:text-faint">
        No deployments yet.
      </div>
    <% end %>
  </div>

  <%# Backups %>
  <% if @app.backups.any? %>
    <div class="mt-8 rounded-large border border-border dark:border-border bg-surface dark:bg-body shadow-soft overflow-hidden">
      <div class="p-4 border-b border-border dark:border-border bg-fill dark:bg-fill">
        <h3 class="text-sm font-semibold text-ink dark:text-white">Recent Backups</h3>
      </div>
      <div class="divide-y divide-border dark:divide-border">
        <% @app.backups.recent.limit(5).each do |backup| %>
          <div class="flex items-center justify-between px-4 py-3">
            <div>
              <div class="text-sm font-medium text-ink dark:text-white"><%= backup.bucket_name %></div>
              <div class="text-xs text-muted dark:text-faint"><%= backup.formatted_size %> · <%= backup.time_ago %></div>
            </div>
            <div class="flex items-center gap-3">
              <%= rui_badge(text: backup.status, color: backup.status == "completed" ? :success : backup.status == "failed" ? :danger : :slate, size: :sm) %>
              <%= rui_button("View", url: backup_path(backup), variant: :link, size: :sm, color: :slate) %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="mt-10 pt-6 border-t border-border dark:border-border">
    <%= rui_button_to("Delete App", app_path(@app), method: :delete, variant: :link, color: :danger, data: { turbo_confirm: "Are you sure you want to delete this app?" }) %>
  </div>
</section>
