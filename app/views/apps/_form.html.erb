<%= form_with model: app, class: "space-y-6" do |f| %>
  <% if app.errors.any? %>
    <div class="rounded-card border border-danger/30 bg-danger-tint p-4">
      <div class="text-sm font-medium text-danger-deep">Please fix the following errors:</div>
      <ul class="mt-2 list-disc list-inside text-sm text-danger-deep">
        <% app.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Basic Info %>
  <div class="rounded-large border border-border bg-surface p-6 shadow-soft space-y-6">
    <h3 class="text-sm font-semibold text-ink">Basic Information</h3>

    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <%= f.label :name, class: "block text-sm font-medium text-body" %>
        <%= f.text_field :name, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm", placeholder: "InventList" %>
      </div>

      <div>
        <%= f.label :slug, class: "block text-sm font-medium text-body" %>
        <%= f.text_field :slug, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm", placeholder: "inventlist" %>
        <p class="mt-1 text-xs text-muted">Auto-generated from name if blank.</p>
      </div>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <%= f.label :server_id, "Server", class: "block text-sm font-medium text-body" %>
        <%= f.collection_select :server_id, servers, :id, :name, { include_blank: "Select server" }, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm" %>
        <p class="mt-1 text-xs text-muted">Only servers with SSH configured are shown.</p>
      </div>

      <div>
        <%= f.label :status, class: "block text-sm font-medium text-body" %>
        <%= f.select :status, App::STATUSES.map { |s| [s.titleize, s] }, {}, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm" %>
      </div>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <%= f.label :domain, class: "block text-sm font-medium text-body" %>
        <%= f.text_field :domain, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm", placeholder: "inventlist.com" %>
      </div>

      <div>
        <%= f.label :port, class: "block text-sm font-medium text-body" %>
        <%= f.number_field :port, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm", placeholder: "3000" %>
      </div>
    </div>
  </div>

  <%# Repository & Deployment %>
  <div class="rounded-large border border-border bg-surface p-6 shadow-soft space-y-6" data-controller="deploy-method-toggle">
    <h3 class="text-sm font-semibold text-ink">Repository & Deployment</h3>

    <%# Deploy Method %>
    <div>
      <span class="block text-sm font-medium text-body mb-2">Deploy Method</span>
      <div class="flex items-center gap-6">
        <label class="flex items-center gap-2 cursor-pointer">
          <%= f.radio_button :deploy_method, "docker", class: "border-border-strong text-ink focus:ring-primary", data: { action: "change->deploy-method-toggle#change" } %>
          <span class="text-sm text-body">Docker</span>
          <span class="text-xs text-faint">(build & run container)</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <%= f.radio_button :deploy_method, "native", class: "border-border-strong text-ink focus:ring-primary", data: { action: "change->deploy-method-toggle#change" } %>
          <span class="text-sm text-body">Native</span>
          <span class="text-xs text-faint">(Puma + systemd)</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <%= f.radio_button :deploy_method, "kamal", class: "border-border-strong text-ink focus:ring-primary", data: { action: "change->deploy-method-toggle#change" } %>
          <span class="text-sm text-body">Kamal</span>
          <span class="text-xs text-faint">(git pull + kamal deploy)</span>
        </label>
      </div>
    </div>

    <div>
      <%= f.label :repository_url, "Repository URL", class: "block text-sm font-medium text-body" %>
      <%= f.text_field :repository_url, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm font-mono", placeholder: "git@github.com:user/repo.git" %>
      <p class="mt-1 text-xs text-muted">SSH URL recommended. Ensure the server has access to the repository.</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <%= f.label :branch, class: "block text-sm font-medium text-body" %>
        <%= f.text_field :branch, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm", placeholder: "main" %>
      </div>

      <div data-deploy-method-toggle-target="dockerFields">
        <%= f.label :dockerfile_path, "Dockerfile Path", class: "block text-sm font-medium text-body" %>
        <%= f.text_field :dockerfile_path, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm font-mono", placeholder: "Dockerfile" %>
      </div>
    </div>

    <div>
      <%= f.label :notes, "Deploy Notes", class: "block text-sm font-medium text-body" %>
      <%= f.text_area :notes, rows: 4, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm", placeholder: "Anything worth remembering about deploying this app..." %>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      <div data-deploy-method-toggle-target="dockerFields">
        <%= f.label :image_name, "Docker Image Name", class: "block text-sm font-medium text-body" %>
        <%= f.text_field :image_name, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm font-mono", placeholder: "conductor/inventlist" %>
        <p class="mt-1 text-xs text-muted">Auto-generated from slug if blank.</p>
      </div>

      <div>
        <%= f.label :health_check_path, "Health Check Path", class: "block text-sm font-medium text-body" %>
        <%= f.text_field :health_check_path, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm font-mono", placeholder: "/up" %>
        <p class="mt-1 text-xs text-muted">Endpoint to verify app is running. Leave blank to skip.</p>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <%= f.check_box :ssl_enabled, class: "rounded border-border-strong text-ink focus:ring-primary" %>
      <%= f.label :ssl_enabled, "Enable SSL (HTTPS)", class: "text-sm text-body" %>
    </div>

    <div class="flex items-start gap-3">
      <%= f.check_box :self_managed, class: "mt-0.5 rounded border-border-strong text-ink focus:ring-primary" %>
      <div>
        <%= f.label :self_managed, "This app is Conductor itself", class: "text-sm text-body" %>
        <p class="mt-1 text-xs text-muted">A self-deploy replaces the container running the deploy, so its status is reconciled when the new release boots. Leave off for normal apps.</p>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-between pt-4">
    <%= link_to "Cancel", apps_path, class: "text-sm font-medium text-body hover:text-ink" %>
    <%= f.submit app.persisted? ? "Update App" : "Create App", class: "inline-flex items-center rounded-lg bg-ink px-4 py-2 text-sm font-medium text-white hover:bg-body cursor-pointer" %>
  </div>
<% end %>
