<%= form_with model: backup, class: "space-y-6" do |f| %>
  <% if backup.errors.any? %>
    <div class="rounded-xl border border-rose-200 bg-rose-50 p-4">
      <div class="text-sm font-medium text-rose-800">Please fix the following errors:</div>
      <ul class="mt-2 list-disc list-inside text-sm text-rose-700">
        <% backup.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-6">
    <h3 class="text-sm font-semibold text-slate-900">Backup Source</h3>
    <p class="text-xs text-slate-500 -mt-4">Choose what to backup - a server's database or an app's database.</p>

    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <%= f.label :server_id, "Server", class: "block text-sm font-medium text-slate-700" %>
        <%= f.collection_select :server_id, @servers, :id, :name, { include_blank: "Select server (optional)" }, class: "mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :app_id, "App", class: "block text-sm font-medium text-slate-700" %>
        <%= f.collection_select :app_id, @apps, :id, :name, { include_blank: "Select app (optional)" }, class: "mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 sm:text-sm" %>
      </div>
    </div>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-6">
    <h3 class="text-sm font-semibold text-slate-900">Storage Destination</h3>

    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <%= f.label :provider, class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :provider, Backup::PROVIDERS.map { |p| [p.titleize.gsub("_", " "), p] }, {}, class: "mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :credential_id, "Credential", class: "block text-sm font-medium text-slate-700" %>
        <% if @credentials.any? %>
          <%= f.collection_select :credential_id, @credentials, :id, :name, { include_blank: "Select credential" }, class: "mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 sm:text-sm" %>
        <% else %>
          <div class="mt-1 text-sm text-slate-500">
            No credentials available. <%= link_to "Add one first", new_credential_path, class: "text-slate-900 hover:underline" %>.
          </div>
        <% end %>
      </div>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <%= f.label :bucket_name, class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :bucket_name, class: "mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 sm:text-sm font-mono", placeholder: "my-backups-bucket" %>
      </div>

      <div>
        <%= f.label :retention_days, "Retention (days)", class: "block text-sm font-medium text-slate-700" %>
        <%= f.number_field :retention_days, class: "mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 sm:text-sm", min: 1, max: 365, value: backup.retention_days || 7 %>
      </div>
    </div>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-6">
    <h3 class="text-sm font-semibold text-slate-900">Schedule</h3>

    <div class="flex items-center gap-3">
      <%= f.check_box :enabled, class: "rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
      <%= f.label :enabled, "Enable automatic backups", class: "text-sm text-slate-700" %>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <%= f.label :schedule, "Frequency", class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :schedule, Backup::SCHEDULES.map { |s| [s.titleize, s] }, {}, class: "mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 sm:text-sm" %>
      </div>

      <% if backup.persisted? && backup.next_run_at %>
        <div>
          <div class="block text-sm font-medium text-slate-700">Next Run</div>
          <div class="mt-1 text-sm text-slate-600"><%= backup.next_run_at&.strftime("%b %d, %Y at %H:%M") || "Not scheduled" %></div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="flex items-center justify-between pt-4">
    <%= link_to "Cancel", backups_path, class: "text-sm font-medium text-slate-600 hover:text-slate-900" %>
    <%= f.submit backup.persisted? ? "Update Backup" : "Create Backup", class: "inline-flex items-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800 cursor-pointer" %>
  </div>
<% end %>
