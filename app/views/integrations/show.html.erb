<% content_for :title, "Integrations · Conductor" %>

<section class="max-w-3xl mx-auto px-4 py-10">
  <div>
    <h1 class="font-display text-2xl text-ink tracking-display">Integrations</h1>
    <p class="mt-1 text-sm text-muted">Connect Conductor to external services. These settings apply across the whole instance.</p>
  </div>

  <div class="mt-8 rounded-large border border-border bg-surface shadow-soft overflow-hidden">
    <div class="flex items-center justify-between gap-4 border-b border-border px-6 py-5">
      <div class="flex items-center gap-3">
        <svg class="h-6 w-6 text-ink" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        <div>
          <div class="text-base font-semibold text-ink">GitHub App</div>
          <p class="text-sm text-muted">One App, every repo across every org — short-lived tokens, no per-repo deploy keys.</p>
        </div>
      </div>
      <% if @configured %>
        <span class="inline-flex items-center rounded-full bg-primary-tint px-2.5 py-1 text-xs font-semibold text-primary ring-1 ring-inset ring-primary/30">Configured</span>
      <% else %>
        <span class="inline-flex items-center rounded-full bg-warning-tint px-2.5 py-1 text-xs font-semibold text-warning ring-1 ring-inset ring-warning/30">Not configured</span>
      <% end %>
    </div>

    <div class="px-6 py-6">
      <p class="text-sm text-body">
        Create the App at
        <a href="https://github.com/settings/apps/new" target="_blank" rel="noopener" class="font-medium text-ink underline">github.com/settings/apps/new</a>
        (Contents → Read-only), generate a private key, install it on your org(s), then paste the credentials below.
        See the <%= link_to "Connect GitHub guide", "/docs/connect-github", class: "font-medium text-ink underline" %>.
      </p>

      <%= form_with url: integrations_path, method: :patch, local: true, class: "mt-6 space-y-5" do %>
        <div>
          <label for="app_id" class="block text-sm font-medium text-body">App ID</label>
          <input type="text" name="app_id" id="app_id" value="<%= @github_app&.api_key %>" placeholder="123456"
                 class="mt-1 block w-full rounded-lg border-border-strong shadow-soft text-sm focus:border-primary focus:ring-primary" />
        </div>

        <div>
          <label for="private_key" class="block text-sm font-medium text-body">Private key (PEM)</label>
          <textarea name="private_key" id="private_key" rows="8" placeholder="-----BEGIN RSA PRIVATE KEY-----&#10;...&#10;-----END RSA PRIVATE KEY-----"
                    class="mt-1 block w-full rounded-lg border-border-strong shadow-soft font-mono text-xs focus:border-primary focus:ring-primary"><%= @github_app&.api_secret %></textarea>
          <p class="mt-1 text-xs text-faint">Stored encrypted and redacted from logs. Paste the full contents of the downloaded <code>.pem</code> file.</p>
        </div>

        <div class="flex items-center gap-3">
          <%= submit_tag "Save GitHub App", class: "inline-flex items-center rounded-lg bg-ink px-4 py-2 text-sm font-medium text-white hover:bg-body cursor-pointer" %>
          <% if @configured %>
            <%= button_to "Verify access", verify_integrations_path, method: :post, class: "inline-flex items-center rounded-lg border border-border-strong px-4 py-2 text-sm font-medium text-body hover:bg-fill" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
