<!DOCTYPE html>
<html>
<head>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.5; color: #1e293b; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: #dc2626; color: white; padding: 20px; border-radius: 8px 8px 0 0; }
    .content { background: #f8fafc; padding: 20px; border: 1px solid #e2e8f0; border-top: none; border-radius: 0 0 8px 8px; }
    .detail { margin: 10px 0; }
    .label { font-weight: 600; color: #64748b; font-size: 12px; text-transform: uppercase; }
    .value { color: #1e293b; }
    .log { background: #1e293b; color: #94a3b8; padding: 15px; border-radius: 6px; font-family: monospace; font-size: 12px; white-space: pre-wrap; max-height: 200px; overflow-y: auto; }
    .button { display: inline-block; background: #1e293b; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none; margin-top: 15px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1 style="margin: 0; font-size: 18px;">Deployment Failed</h1>
    </div>
    <div class="content">
      <p>A deployment has failed and needs attention.</p>

      <div class="detail">
        <div class="label">App</div>
        <div class="value"><%= @app.name %></div>
      </div>

      <div class="detail">
        <div class="label">Server</div>
        <div class="value"><%= @app.server&.name || "—" %></div>
      </div>

      <div class="detail">
        <div class="label">Duration</div>
        <div class="value"><%= @deployment.formatted_duration %></div>
      </div>

      <% if @deployment.log.present? %>
        <div class="detail">
          <div class="label">Last Log Lines</div>
          <div class="log"><%= @deployment.log.split("\n").last(10).join("\n") %></div>
        </div>
      <% end %>

      <a href="<%= deployment_url(@deployment) %>" class="button">View Deployment</a>
    </div>
  </div>
</body>
</html>
