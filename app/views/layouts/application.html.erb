<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Conductor" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Conductor">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-bg text-body font-sans antialiased">
    <div class="min-h-screen flex flex-col">
      <header class="sticky top-0 z-30 border-b border-border bg-surface/80 backdrop-blur">
        <div class="max-w-7xl mx-auto px-4">
          <div class="h-14 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="h-9 w-9 rounded-card bg-ink text-white flex items-center justify-center text-sm font-semibold">
                C
              </div>
              <div class="leading-tight">
                <div class="text-sm font-semibold text-ink">Conductor</div>
                <div class="text-xs text-muted">Ops control panel</div>
              </div>
            </div>
            <% if user_signed_in? %>
              <nav class="flex items-center gap-1 text-sm font-medium text-body">
                <%= link_to "Overview", dashboard_path, class: "px-3 py-1.5 rounded-full #{request.path == dashboard_path ? 'bg-ink text-white' : 'hover:bg-fill-strong'}" %>
                <%= link_to "Chat", conversations_path, class: "px-3 py-1.5 rounded-full #{request.path.start_with?('/conversations') ? 'bg-ink text-white' : 'hover:bg-fill-strong'}" %>
                <%= link_to "Servers", servers_path, class: "px-3 py-1.5 rounded-full #{request.path.start_with?('/servers') ? 'bg-ink text-white' : 'hover:bg-fill-strong'}" %>
                <%= link_to "Apps", apps_path, class: "px-3 py-1.5 rounded-full #{request.path.start_with?('/apps') ? 'bg-ink text-white' : 'hover:bg-fill-strong'}" %>
                <%= link_to "Backups", backups_path, class: "px-3 py-1.5 rounded-full #{request.path.start_with?('/backups') ? 'bg-ink text-white' : 'hover:bg-fill-strong'}" %>
                <%= link_to "Databases", database_clusters_path, class: "px-3 py-1.5 rounded-full #{request.path.start_with?('/database_clusters') ? 'bg-ink text-white' : 'hover:bg-fill-strong'}" %>
                <%= link_to "Credentials", credentials_path, class: "px-3 py-1.5 rounded-full #{request.path.start_with?('/credentials') ? 'bg-ink text-white' : 'hover:bg-fill-strong'}" %>
                <%= link_to "SSH Keys", ssh_keys_path, class: "px-3 py-1.5 rounded-full #{request.path.start_with?('/ssh_keys') ? 'bg-ink text-white' : 'hover:bg-fill-strong'}" %>
                <%= link_to "Members", members_path, class: "px-3 py-1.5 rounded-full #{request.path.start_with?('/members') ? 'bg-ink text-white' : 'hover:bg-fill-strong'}" %>
                <% if current_admin? %>
                  <%= link_to "Integrations", integrations_path, class: "px-3 py-1.5 rounded-full #{request.path.start_with?('/integrations') ? 'bg-ink text-white' : 'hover:bg-fill-strong'}" %>
                  <%= link_to "Admin", admin_organizations_path, class: "px-3 py-1.5 rounded-full #{request.path.start_with?('/admin') ? 'bg-ink text-white' : 'hover:bg-fill-strong'}" %>
                <% end %>
                <span class="ml-2 text-faint">|</span>
                <%= render "organizations/switcher" %>
                <span class="ml-2 text-xs text-muted"><%= current_user.email %></span>
                <% if current_admin? %>
                  <span class="text-xs text-warning">(admin)</span>
                <% end %>
                <%= button_to "Sign out", user_sign_out_path, method: :delete, class: "ml-2 px-3 py-1.5 rounded-full text-muted hover:bg-fill-strong" %>
              </nav>
            <% else %>
              <%= link_to "Sign in", user_sign_in_path, class: "px-3 py-1.5 rounded-full bg-ink text-white text-sm font-medium" %>
            <% end %>
          </div>
        </div>
      </header>

      <main class="flex-1">
        <% if notice.present? %>
          <div class="bg-primary-tint border-b border-primary/30">
            <div class="max-w-7xl mx-auto px-4 py-3">
              <p class="text-sm text-primary"><%= notice %></p>
            </div>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="bg-danger-tint border-b border-danger/30">
            <div class="max-w-7xl mx-auto px-4 py-3">
              <p class="text-sm text-danger-deep"><%= alert %></p>
            </div>
          </div>
        <% end %>
        <%= yield %>
      </main>

      <footer class="border-t border-border bg-surface">
        <div class="max-w-7xl mx-auto px-4 py-6 text-xs text-muted flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
          <span>Conductor Ops · Rails 8 + Turbo</span>
          <span>Monitoring VMs, R2 backups, and Active Storage</span>
        </div>
      </footer>
    </div>
  </body>
</html>
