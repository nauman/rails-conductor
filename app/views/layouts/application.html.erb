<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Conductor" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Conductor">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# SEO + social cards %>
    <meta name="description" content="<%= content_for?(:description) ? yield(:description) : "Conductor — the control plane for self-hosted Ruby on Rails. Deploy, route, databases, backups, and server maintenance across your own servers (Kamal, Docker, native), driven by UI, CLI, and AI agents over MCP." %>">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Conductor">
    <meta property="og:title" content="<%= content_for?(:title) ? strip_tags(yield(:title)) : "Conductor — control plane for self-hosted Ruby on Rails" %>">
    <meta property="og:description" content="Deploy, route, databases, backups, and server maintenance for your Ruby on Rails apps across your own servers — Kamal, Docker, native — driven by UI, CLI, and AI agents over MCP.">
    <meta property="og:image" content="<%= request.base_url %>/og.png">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Conductor — control plane for self-hosted Ruby on Rails">
    <meta name="twitter:description" content="Self-hosted Ruby on Rails ops: deploy, route, databases, backups, maintenance — UI, CLI, and AI agents over MCP.">
    <meta name="twitter:image" content="<%= request.base_url %>/og.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-bg text-body font-sans antialiased">
    <div class="min-h-screen flex flex-col">
      <header class="sticky top-0 z-30 border-b border-border bg-surface/85 backdrop-blur">
        <div class="max-w-[88rem] mx-auto px-4">
          <div class="h-16 flex items-center gap-4">
            <%= link_to (user_signed_in? ? dashboard_path : root_path), class: "flex items-center gap-2.5 shrink-0" do %>
              <span class="h-9 w-9 rounded-card bg-primary text-white flex items-center justify-center font-display text-lg leading-none">C</span>
              <span class="leading-tight hidden sm:block">
                <span class="block font-display text-lg text-ink">Conductor</span>
                <span class="block text-2xs uppercase tracking-label text-faint">Ops control panel</span>
              </span>
            <% end %>

            <% if user_signed_in? %>
              <nav class="flex-1 min-w-0 overflow-x-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
                <div class="flex items-center gap-0.5 whitespace-nowrap text-[13px] font-medium">
                  <%= nav_link "Overview", dashboard_path, active: request.path == dashboard_path %>
                  <%= nav_link "Chat", conversations_path, active: request.path.start_with?('/conversations') %>
                  <%= nav_link "Servers", servers_path, active: request.path.start_with?('/servers') %>
                  <%= nav_link "Apps", apps_path, active: request.path.start_with?('/apps') %>
                  <%= nav_link "Backups", backups_path, active: request.path.start_with?('/backups') %>
                  <%= nav_link "Databases", database_clusters_path, active: request.path.start_with?('/database_clusters') %>
                  <%= nav_link "Pulls", database_pulls_path, active: request.path.start_with?('/database_pulls') %>
                  <%= nav_link "Credentials", credentials_path, active: request.path.start_with?('/credentials') %>
                  <%= nav_link "SSH Keys", ssh_keys_path, active: request.path.start_with?('/ssh_keys') %>
                  <%= nav_link "Members", members_path, active: request.path.start_with?('/members') %>
                  <%= nav_link "Tokens", mcp_tokens_path, active: request.path.start_with?('/mcp_tokens') %>
                  <% if current_admin? %>
                    <%= nav_link "Integrations", integrations_path, active: request.path.start_with?('/integrations') %>
                    <%= nav_link "Admin", admin_organizations_path, active: request.path.start_with?('/admin') %>
                  <% end %>
                </div>
              </nav>

              <div class="flex items-center gap-3 shrink-0 pl-3 border-l border-border">
                <%= render "organizations/switcher" %>
                <div class="hidden lg:flex flex-col items-end leading-tight">
                  <span class="text-2xs text-muted max-w-[12rem] truncate"><%= current_user.email %></span>
                  <% if current_admin? %>
                    <span class="text-2xs uppercase tracking-label text-warning">Admin</span>
                  <% end %>
                </div>
                <%= button_to "Sign out", user_sign_out_path, method: :delete, class: "shrink-0 px-3 py-1.5 rounded-pill text-2xs font-semibold uppercase tracking-label text-muted hover:text-ink hover:bg-fill-strong" %>
              </div>
            <% else %>
              <div class="flex-1"></div>
              <%= link_to "Sign in", user_sign_in_path, class: "shrink-0 px-4 py-1.5 rounded-pill bg-ink text-white text-sm font-medium hover:bg-body" %>
            <% end %>
          </div>
        </div>
      </header>

      <main class="flex-1">
        <% if notice.present? %>
          <div class="bg-primary-tint border-b border-primary/30">
            <div class="max-w-7xl mx-auto px-4 py-3">
              <p class="text-sm text-primary"><%= notice %></p>
            </div>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="bg-danger-tint border-b border-danger/30">
            <div class="max-w-7xl mx-auto px-4 py-3">
              <p class="text-sm text-danger-deep"><%= alert %></p>
            </div>
          </div>
        <% end %>
        <%= yield %>
      </main>

      <footer class="border-t border-border bg-surface">
        <div class="max-w-7xl mx-auto px-4 py-6 text-xs text-muted flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
          <span>Conductor Ops · Rails 8 + Turbo</span>
          <span>Monitoring VMs, R2 backups, and Active Storage</span>
        </div>
      </footer>
    </div>
  </body>
</html>
