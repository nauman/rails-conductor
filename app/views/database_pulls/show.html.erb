<% content_for :title, "Database Pull ##{@pull.id}" %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-ink">Database Pull #<%= @pull.id %></h1>
      <p class="text-sm text-muted mt-1">
        <%= @pull.source_label %> from
        <%= link_to @pull.server.name, server_path(@pull.server), class: "text-info hover:underline" %>
        <% if @pull.restore? %>&middot; restoring into <code class="font-mono"><%= @pull.restore_target %></code><% end %>
        &middot; started <%= time_ago_in_words(@pull.created_at) %> ago
      </p>
    </div>
    <div class="flex items-center gap-3">
      <span id="pull-status-badge" class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
        <%= case @pull.status
            when 'pending' then 'bg-fill-strong text-body'
            when 'running' then 'bg-info-tint text-info'
            when 'success' then 'bg-primary-tint text-primary'
            when 'failed'  then 'bg-danger-tint text-danger-deep'
            end %>">
        <span id="pull-status-text"><%= @pull.status.capitalize %></span>
      </span>
      <%= link_to "All pulls", database_pulls_path, class: "text-sm text-muted hover:text-body" %>
    </div>
  </div>

  <div class="bg-ink rounded-card overflow-hidden shadow-lg">
    <div class="flex items-center justify-between px-4 py-2 bg-ink border-b border-white/10">
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-danger-tint0/70"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
        <div class="w-3 h-3 rounded-full bg-primary-tint0/70"></div>
      </div>
      <span class="text-xs text-muted font-mono"><%= @pull.server.ip_address %></span>
      <div id="spinner" class="<%= @pull.done? ? 'hidden' : '' %>">
        <svg class="animate-spin h-4 w-4 text-info-bright" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 22 6.477 22 12h-4z"></path>
        </svg>
      </div>
    </div>
    <pre id="pull-log"
         class="text-primary-sage font-mono text-xs p-4 overflow-auto max-h-[600px] whitespace-pre-wrap break-words"
    ><%= @pull.log.presence || "Waiting for output...\n" %></pre>
  </div>

  <div class="mt-3 flex items-center justify-between text-xs text-faint">
    <span>
      <% if @pull.local_dump_path.present? %>Saved to <code class="font-mono"><%= @pull.local_dump_path %></code> (<%= @pull.formatted_size %>)<% end %>
    </span>
    <% if @pull.duration %><span>Duration: <%= @pull.duration %>s</span><% end %>
  </div>
</div>

<% unless @pull.done? %>
<script>
(function() {
  const logEl   = document.getElementById('pull-log');
  const spinEl  = document.getElementById('spinner');
  const badgeEl = document.getElementById('pull-status-badge');
  const textEl  = document.getElementById('pull-status-text');

  const consumer = ActionCable.createConsumer();
  const sub = consumer.subscriptions.create(
    { channel: "DatabasePullChannel", database_pull_id: <%= @pull.id %> },
    {
      received(data) {
        if (data.line) {
          if (logEl.textContent === "Waiting for output...\n") logEl.textContent = '';
          logEl.textContent += data.line;
          logEl.scrollTop = logEl.scrollHeight;
        }
        if (data.status) {
          textEl.textContent = data.status.charAt(0).toUpperCase() + data.status.slice(1);
          const colors = { running: 'bg-info-tint text-info', success: 'bg-primary-tint text-primary', failed: 'bg-danger-tint text-danger-deep' };
          badgeEl.className = 'inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ' + (colors[data.status] || 'bg-fill-strong text-body');
        }
        if (data.done) {
          spinEl.classList.add('hidden');
          sub.unsubscribe();
        }
      }
    }
  );
})();
</script>
<% end %>
