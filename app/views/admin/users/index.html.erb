<section class="mx-auto max-w-4xl">
  <div class="flex items-center justify-between">
    <h1 class="font-display text-xl text-ink">Admin · Users</h1>
    <nav class="flex gap-1 text-sm">
      <%= link_to "Organizations", admin_organizations_path, class: "px-3 py-1.5 rounded-full hover:bg-fill-strong text-body" %>
      <%= link_to "Users", admin_users_path, class: "px-3 py-1.5 rounded-full bg-ink text-white" %>
      <%= link_to "MCP Activity", admin_mcp_calls_path, class: "px-3 py-1.5 rounded-full hover:bg-fill-strong text-body" %>
    </nav>
  </div>

  <div class="mt-6 rounded-large border border-border bg-surface shadow-soft">
    <table class="w-full text-sm">
      <thead class="text-left text-xs uppercase tracking-wide text-faint">
        <tr class="border-b border-border">
          <th class="px-5 py-3">Email</th>
          <th class="px-5 py-3">Role</th>
          <th class="px-5 py-3">Organizations</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <% @users.each do |user| %>
          <tr>
            <td class="px-5 py-3 font-medium text-ink"><%= user.email %></td>
            <td class="px-5 py-3">
              <% if user.admin? %>
                <%= rui_badge(text: "webmaster", color: :primary, size: :sm) %>
              <% else %>
                <span class="text-xs text-faint">user</span>
              <% end %>
            </td>
            <td class="px-5 py-3 text-body"><%= user.organizations.map(&:name).join(", ").presence || "—" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
