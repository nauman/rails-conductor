<section class="mx-auto max-w-4xl">
  <div class="flex items-center justify-between">
    <h1 class="text-xl font-semibold text-slate-900">Admin · Users</h1>
    <nav class="flex gap-1 text-sm">
      <%= link_to "Organizations", admin_organizations_path, class: "px-3 py-1.5 rounded-full hover:bg-slate-100 text-slate-600" %>
      <%= link_to "Users", admin_users_path, class: "px-3 py-1.5 rounded-full bg-slate-900 text-white" %>
      <%= link_to "MCP Activity", admin_mcp_calls_path, class: "px-3 py-1.5 rounded-full hover:bg-slate-100 text-slate-600" %>
    </nav>
  </div>

  <div class="mt-6 rounded-2xl border border-slate-200 bg-white shadow-sm">
    <table class="w-full text-sm">
      <thead class="text-left text-xs uppercase tracking-wide text-slate-400">
        <tr class="border-b border-slate-100">
          <th class="px-5 py-3">Email</th>
          <th class="px-5 py-3">Role</th>
          <th class="px-5 py-3">Organizations</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @users.each do |user| %>
          <tr>
            <td class="px-5 py-3 font-medium text-slate-800"><%= user.email %></td>
            <td class="px-5 py-3">
              <% if user.admin? %>
                <%= rui_badge(text: "webmaster", color: :primary, size: :sm) %>
              <% else %>
                <span class="text-xs text-slate-400">user</span>
              <% end %>
            </td>
            <td class="px-5 py-3 text-slate-600"><%= user.organizations.map(&:name).join(", ").presence || "—" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
