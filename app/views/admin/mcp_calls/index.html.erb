<section class="mx-auto max-w-5xl">
  <div class="flex items-center justify-between">
    <h1 class="font-display text-xl text-ink">Admin · MCP Activity</h1>
    <nav class="flex gap-1 text-sm">
      <%= link_to "Organizations", admin_organizations_path, class: "px-3 py-1.5 rounded-full hover:bg-fill-strong text-body" %>
      <%= link_to "Users", admin_users_path, class: "px-3 py-1.5 rounded-full hover:bg-fill-strong text-body" %>
      <%= link_to "MCP Activity", admin_mcp_calls_path, class: "px-3 py-1.5 rounded-full bg-ink text-white" %>
    </nav>
  </div>

  <p class="mt-2 text-sm text-muted">Tool calls made by agents through the MCP endpoint (<code>POST /mcp/call</code>). Most recent first.</p>

  <div class="mt-6 rounded-large border border-border bg-surface shadow-soft overflow-hidden">
    <table class="w-full text-sm">
      <thead class="text-left text-xs uppercase tracking-wide text-faint">
        <tr class="border-b border-border">
          <th class="px-5 py-3">When</th>
          <th class="px-5 py-3">Tool</th>
          <th class="px-5 py-3">Status</th>
          <th class="px-5 py-3">Duration</th>
          <th class="px-5 py-3">Caller</th>
          <th class="px-5 py-3">Org</th>
          <th class="px-5 py-3">Arguments / Error</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <% @mcp_calls.each do |c| %>
          <tr class="align-top">
            <td class="px-5 py-3 whitespace-nowrap text-muted"><%= time_ago_in_words(c.created_at) %> ago</td>
            <td class="px-5 py-3 font-mono text-ink"><%= c.tool_name %></td>
            <td class="px-5 py-3">
              <span class="<%= c.success? ? "bg-primary-tint text-primary" : "bg-danger-tint text-danger-deep" %> rounded-full px-2 py-0.5 text-xs font-medium"><%= c.status %></span>
            </td>
            <td class="px-5 py-3 whitespace-nowrap text-muted"><%= c.duration_ms ? "#{c.duration_ms} ms" : "—" %></td>
            <td class="px-5 py-3 text-body"><%= c.user&.email || "system" %></td>
            <td class="px-5 py-3 text-body"><%= c.organization&.name || "—" %></td>
            <td class="px-5 py-3 text-body">
              <% if c.success? %>
                <code class="block max-w-md truncate text-xs text-muted"><%= c.arguments.to_json %></code>
              <% else %>
                <span class="text-xs text-danger"><%= truncate(c.error, length: 120) %></span>
              <% end %>
            </td>
          </tr>
        <% end %>
        <% if @mcp_calls.empty? %>
          <tr><td colspan="7" class="px-5 py-8 text-center text-faint">No MCP calls recorded yet.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
