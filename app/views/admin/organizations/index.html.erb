<section class="mx-auto max-w-4xl">
  <div class="flex items-center justify-between">
    <h1 class="font-display text-xl text-ink">Admin · Organizations</h1>
    <nav class="flex gap-1 text-sm">
      <%= link_to "Organizations", admin_organizations_path, class: "px-3 py-1.5 rounded-full bg-ink text-white" %>
      <%= link_to "Users", admin_users_path, class: "px-3 py-1.5 rounded-full hover:bg-fill-strong text-body" %>
      <%= link_to "MCP Activity", admin_mcp_calls_path, class: "px-3 py-1.5 rounded-full hover:bg-fill-strong text-body" %>
    </nav>
  </div>

  <div class="mt-6 rounded-large border border-border bg-surface shadow-soft">
    <table class="w-full text-sm">
      <thead class="text-left text-xs uppercase tracking-wide text-faint">
        <tr class="border-b border-border">
          <th class="px-5 py-3">Organization</th>
          <th class="px-5 py-3">Members</th>
          <th class="px-5 py-3">Onboarded</th>
          <th class="px-5 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <% @organizations.each do |org| %>
          <tr>
            <td class="px-5 py-3 font-medium text-ink"><%= org.name %></td>
            <td class="px-5 py-3 text-body"><%= org.users.size %></td>
            <td class="px-5 py-3">
              <%= rui_badge(text: org.onboarded? ? "yes" : "pending", color: org.onboarded? ? :success : :warning, size: :sm) %>
            </td>
            <td class="px-5 py-3 text-right">
              <%= link_to "View", admin_organization_path(org), class: "text-xs font-medium text-primary hover:text-primary" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
