<%= form_with model: ssh_key, class: "space-y-6" do |f| %>
  <% if ssh_key.errors.any? %>
    <div class="rounded-xl border border-rose-200 bg-rose-50 p-4">
      <div class="text-sm font-medium text-rose-800">Please fix the following errors:</div>
      <ul class="mt-2 list-disc list-inside text-sm text-rose-700">
        <% ssh_key.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-6">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 sm:text-sm", placeholder: "Production Key" %>
    </div>

    <div>
      <%= f.label :private_key, class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_area :private_key, rows: 12, class: "mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 sm:text-sm font-mono text-xs", placeholder: "-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----" %>
      <p class="mt-1 text-xs text-slate-500">Paste your private key. It will be encrypted at rest.</p>
    </div>

    <div>
      <%= f.label :passphrase, "Passphrase (optional)", class: "block text-sm font-medium text-slate-700" %>
      <%= f.password_field :passphrase, class: "mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 sm:text-sm", placeholder: "If your key has a passphrase" %>
      <p class="mt-1 text-xs text-slate-500">Leave blank if your key doesn't have a passphrase.</p>
    </div>
  </div>

  <div class="rounded-xl border border-amber-200 bg-amber-50 p-4">
    <div class="flex gap-3">
      <svg class="h-5 w-5 text-amber-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <div>
        <div class="text-sm font-medium text-amber-800">Security note</div>
        <p class="mt-1 text-sm text-amber-700">
          Private keys are encrypted in the database. For production use, consider using a dedicated key with limited permissions.
        </p>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-between pt-4">
    <%= link_to "Cancel", ssh_keys_path, class: "text-sm font-medium text-slate-600 hover:text-slate-900" %>
    <%= f.submit ssh_key.persisted? ? "Update SSH Key" : "Add SSH Key", class: "inline-flex items-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800 cursor-pointer" %>
  </div>
<% end %>
