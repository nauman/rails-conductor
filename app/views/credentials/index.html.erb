<% content_for :title, "Credentials · Conductor" %>

<section class="max-w-7xl mx-auto px-4 py-10">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="font-display text-2xl text-ink tracking-display">Credentials</h1>
      <p class="mt-1 text-sm text-muted">Manage API keys and secrets.</p>
    </div>
    <%= link_to new_credential_path, class: "inline-flex items-center gap-2 rounded-lg bg-ink px-4 py-2 text-sm font-medium text-white hover:bg-body" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Add Credential
    <% end %>
  </div>

  <% if @credentials.any? %>
    <div class="mt-6 rounded-large border border-border bg-surface shadow-soft overflow-hidden">
      <table class="min-w-full divide-y divide-border">
        <thead class="bg-fill">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Name</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Provider</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">API Key</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Status</th>
            <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wide text-muted">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          <% @credentials.each do |credential| %>
            <tr>
              <td class="px-6 py-4 text-sm font-medium text-ink"><%= credential.name %></td>
              <td class="px-6 py-4 text-sm text-muted"><%= credential.provider.titleize %></td>
              <td class="px-6 py-4 text-sm text-muted">
                <code class="bg-fill-strong px-2 py-1 rounded text-xs"><%= credential.masked_api_key %></code>
              </td>
              <td class="px-6 py-4">
                <% if credential.active? %>
                  <span class="inline-flex items-center rounded-full bg-primary-tint px-2.5 py-1 text-xs font-semibold text-primary ring-1 ring-inset ring-primary/30">Active</span>
                <% else %>
                  <span class="inline-flex items-center rounded-full bg-fill-strong px-2.5 py-1 text-xs font-semibold text-body ring-1 ring-inset ring-border">Inactive</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-right text-sm">
                <%= link_to "Edit", edit_credential_path(credential), class: "font-medium text-body hover:text-ink" %>
                <span class="text-faint mx-2">·</span>
                <%= button_to "Delete", credential_path(credential), method: :delete,
                    data: { turbo_confirm: "Are you sure?" },
                    class: "font-medium text-danger hover:text-danger-deep" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="mt-6 rounded-large border border-dashed border-border-strong bg-fill p-12 text-center">
      <div class="text-sm text-muted">No credentials yet.</div>
      <%= link_to "Add your first credential", new_credential_path, class: "mt-2 inline-block text-sm font-medium text-ink hover:underline" %>
    </div>
  <% end %>
</section>
