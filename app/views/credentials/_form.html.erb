<%= form_with model: credential, class: "space-y-6" do |f| %>
  <% if credential.errors.any? %>
    <div class="rounded-xl border border-rose-200 bg-rose-50 p-4">
      <div class="text-sm font-medium text-rose-800">Please fix the following errors:</div>
      <ul class="mt-2 list-disc list-inside text-sm text-rose-700">
        <% credential.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-6">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 sm:text-sm", placeholder: "Production Cloudflare" %>
    </div>

    <div>
      <%= f.label :provider, class: "block text-sm font-medium text-slate-700" %>
      <%= f.select :provider, Credential::PROVIDERS.map { |p| [p.titleize, p] }, { include_blank: "Select provider" }, class: "mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :api_key, class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :api_key, class: "mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 sm:text-sm font-mono", placeholder: "sk_live_..." %>
      <p class="mt-1 text-xs text-slate-500">This value is encrypted at rest.</p>
    </div>

    <div>
      <%= f.label :api_secret, "API Secret (optional)", class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :api_secret, class: "mt-1 block w-full rounded-lg border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 sm:text-sm font-mono", placeholder: "Optional secret key" %>
      <p class="mt-1 text-xs text-slate-500">For providers that require both key and secret.</p>
    </div>

    <div class="flex items-center gap-3">
      <%= f.check_box :active, class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
      <%= f.label :active, "Active", class: "text-sm font-medium text-slate-700" %>
    </div>
  </div>

  <div class="flex items-center justify-between pt-4">
    <%= link_to "Cancel", credentials_path, class: "text-sm font-medium text-slate-600 hover:text-slate-900" %>
    <%= f.submit credential.persisted? ? "Update Credential" : "Create Credential", class: "inline-flex items-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800 cursor-pointer" %>
  </div>
<% end %>
