<%= form_with model: credential, class: "space-y-6" do |f| %>
  <% if credential.errors.any? %>
    <div class="rounded-card border border-danger/30 bg-danger-tint p-4">
      <div class="text-sm font-medium text-danger-deep">Please fix the following errors:</div>
      <ul class="mt-2 list-disc list-inside text-sm text-danger-deep">
        <% credential.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="rounded-large border border-border bg-surface p-6 shadow-soft space-y-6">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-body" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm", placeholder: "Production Cloudflare" %>
    </div>

    <div>
      <%= f.label :provider, class: "block text-sm font-medium text-body" %>
      <%= f.select :provider, Credential::PROVIDERS.map { |p| [p.titleize, p] }, { include_blank: "Select provider" }, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm" %>
    </div>

    <div>
      <%= f.label :api_key, class: "block text-sm font-medium text-body" %>
      <%= f.text_field :api_key, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm font-mono", placeholder: "sk_live_..." %>
      <p class="mt-1 text-xs text-muted">This value is encrypted at rest.</p>
    </div>

    <div>
      <%= f.label :api_secret, "API Secret (optional)", class: "block text-sm font-medium text-body" %>
      <%= f.text_field :api_secret, class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm font-mono", placeholder: "Optional secret key" %>
      <p class="mt-1 text-xs text-muted">For providers that require both key and secret.</p>
    </div>

    <div class="flex items-center gap-3">
      <%= f.check_box :active, class: "h-4 w-4 rounded border-border-strong text-ink focus:ring-primary" %>
      <%= f.label :active, "Active", class: "text-sm font-medium text-body" %>
    </div>
  </div>

  <div class="flex items-center justify-between pt-4">
    <%= link_to "Cancel", credentials_path, class: "text-sm font-medium text-body hover:text-ink" %>
    <%= f.submit credential.persisted? ? "Update Credential" : "Create Credential", class: "inline-flex items-center rounded-lg bg-ink px-4 py-2 text-sm font-medium text-white hover:bg-body cursor-pointer" %>
  </div>
<% end %>
