<% content_for :title, "Sign in · Conductor" %>

<section class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <div class="inline-flex h-12 w-12 rounded-card bg-ink text-white items-center justify-center text-lg font-semibold mb-4">
        C
      </div>
      <h1 class="font-display text-2xl text-ink tracking-display">Sign in to Conductor</h1>
      <p class="mt-2 text-sm text-muted">Enter your email to receive a magic link</p>
    </div>

    <div class="rounded-large border border-border bg-surface p-6 shadow-soft">
      <%= form_tag users_sign_in_path, method: :post, class: "space-y-4", data: { turbo: false } do %>
        <div>
          <label for="passwordless_email" class="block text-sm font-medium text-body">Email address</label>
          <input type="email" name="passwordless[email]" id="passwordless_email"
                 required autofocus autocomplete="email"
                 placeholder="you@example.com"
                 class="mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm">
        </div>

        <div>
          <button type="submit" class="w-full inline-flex justify-center items-center rounded-lg bg-ink px-4 py-2.5 text-sm font-medium text-white hover:bg-body cursor-pointer">
            Send magic link
          </button>
        </div>
      <% end %>
    </div>

    <p class="mt-6 text-center text-xs text-muted">
      We'll email you a secure link to sign in.<br>
      No password required.
    </p>
  </div>
</section>
