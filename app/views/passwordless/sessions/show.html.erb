<% content_for :title, "Check your email · Conductor" %>

<section class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-md text-center">
    <div class="inline-flex h-12 w-12 rounded-xl bg-gradient-to-br from-emerald-500 to-emerald-600 text-white items-center justify-center text-lg mb-4">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
    </div>
    <h1 class="text-2xl font-semibold text-slate-900">Check your email</h1>
    <p class="mt-2 text-sm text-slate-500">
      We sent a magic link to <strong class="text-slate-700"><%= @session.authenticatable.email %></strong>
    </p>

    <div class="mt-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm text-slate-600">
        Click the link in the email to sign in. The link expires in 10 minutes.
      </p>

      <% if Rails.env.development? %>
        <div class="mt-4 pt-4 border-t border-slate-200">
          <p class="text-xs text-slate-500 mb-2">Development mode:</p>
          <%= link_to "Open Letter Opener", "/letter_opener", target: "_blank", class: "inline-flex items-center gap-2 text-sm font-medium text-slate-900 hover:underline" %>
        </div>
      <% end %>
    </div>

    <p class="mt-6 text-xs text-slate-500">
      Didn't receive it? Check your spam folder or
      <%= link_to "try again", send(:"#{@resource}_sign_in_path"), class: "text-slate-900 hover:underline" %>.
    </p>
  </div>
</section>
