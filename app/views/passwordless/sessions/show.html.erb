<% content_for :title, "Check your email · Conductor" %>

<section class="min-h-[80vh] flex items-center justify-center px-4">
  <div class="w-full max-w-md text-center">
    <div class="inline-flex h-12 w-12 rounded-card bg-fill text-white items-center justify-center text-lg mb-4">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
    </div>
    <h1 class="font-display text-2xl text-ink tracking-display">Check your email</h1>
    <p class="mt-2 text-sm text-muted">
      We sent a magic link to <strong class="text-body"><%= @session.authenticatable.email %></strong>
    </p>

    <div class="mt-8 rounded-large border border-border bg-surface p-6 shadow-soft">
      <p class="text-sm text-body">
        Click the link in the email to sign in. The link expires in 10 minutes.
      </p>

      <% if Rails.env.development? %>
        <div class="mt-4 pt-4 border-t border-border">
          <p class="text-xs text-muted mb-2">Development mode:</p>
          <%= link_to "Open Letter Opener", "/letter_opener", target: "_blank", class: "inline-flex items-center gap-2 text-sm font-medium text-ink hover:underline" %>
        </div>
      <% end %>
    </div>

    <p class="mt-6 text-xs text-muted">
      Didn't receive it? Check your spam folder or
      <%= link_to "try again", user_sign_in_path, class: "text-ink hover:underline" %>.
    </p>
  </div>
</section>
