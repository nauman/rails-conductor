<%= form_with(model: script, class: "space-y-5") do |f| %>
  <% if script.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md px-4 py-3 text-sm text-red-700">
      <ul class="list-disc list-inside"><% script.errors.each do |e| %><li><%= e.full_message %></li><% end %></ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "w-full text-sm border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <div>
    <%= f.label :script_type, "Type", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :script_type, Script::TYPES.map { |t| [t.capitalize, t] }, {}, class: "w-full text-sm border border-gray-300 rounded-md px-3 py-2" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 2, class: "w-full text-sm border border-gray-300 rounded-md px-3 py-2" %>
  </div>

  <div>
    <%= f.label :body, "Script (bash)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :body, rows: 24, class: "w-full font-mono text-xs border border-gray-300 rounded-md px-3 py-2 bg-gray-950 text-green-400" %>
  </div>

  <div class="flex items-center justify-between">
    <%= f.submit class: "px-4 py-2 text-sm font-medium rounded-md bg-gray-900 hover:bg-gray-800 text-white cursor-pointer" %>
    <%= link_to "Cancel", scripts_path, class: "text-sm text-gray-500" %>
  </div>
<% end %>
