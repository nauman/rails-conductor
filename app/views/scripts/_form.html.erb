<%= form_with(model: script, class: "space-y-5") do |f| %>
  <% if script.errors.any? %>
    <div class="bg-danger-tint border border-danger/30 rounded-md px-4 py-3 text-sm text-danger-deep">
      <ul class="list-disc list-inside"><% script.errors.each do |e| %><li><%= e.full_message %></li><% end %></ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-body mb-1" %>
    <%= f.text_field :name, class: "w-full text-sm border border-border-strong rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-info-tint0" %>
  </div>

  <div>
    <%= f.label :script_type, "Type", class: "block text-sm font-medium text-body mb-1" %>
    <%= f.select :script_type, Script::TYPES.map { |t| [t.capitalize, t] }, {}, class: "w-full text-sm border border-border-strong rounded-md px-3 py-2" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-body mb-1" %>
    <%= f.text_area :description, rows: 2, class: "w-full text-sm border border-border-strong rounded-md px-3 py-2" %>
  </div>

  <div>
    <%= f.label :body, "Script (bash)", class: "block text-sm font-medium text-body mb-1" %>
    <%= f.text_area :body, rows: 24, class: "w-full font-mono text-xs border border-border-strong rounded-md px-3 py-2 bg-ink text-primary-sage" %>
  </div>

  <div class="flex items-center justify-between">
    <%= f.submit class: "px-4 py-2 text-sm font-medium rounded-md bg-ink hover:bg-body text-white cursor-pointer" %>
    <%= link_to "Cancel", scripts_path, class: "text-sm text-muted" %>
  </div>
<% end %>
