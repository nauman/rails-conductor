<p>Hi,</p>

<p><%= @invitation.invited_by.email %> invited you to join <strong><%= @organization.name %></strong> on Conductor.</p>

<p>
  <%= link_to "Accept invitation", @accept_url, style: "display:inline-block;padding:10px 16px;background:#4f46e5;color:#fff;border-radius:6px;text-decoration:none;" %>
</p>

<p>Or paste this link into your browser:<br>
  <%= link_to @accept_url, @accept_url %>
</p>

<p style="color:#64748b;font-size:12px;">If you weren't expecting this, you can ignore this email.</p>
