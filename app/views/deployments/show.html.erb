<% content_for :title, "Deployment ##{@deployment.id} · #{@app.name} · Conductor" %>

<section class="max-w-5xl mx-auto px-4 py-10">
  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="text-2xl font-semibold text-slate-900">Deployment #<%= @deployment.id %></h1>
        <span class="<%= status_badge(@deployment.status) %>"><%= @deployment.status %></span>
      </div>
      <p class="mt-1 text-sm text-slate-500">
        <%= link_to @app.name, app_path(@app), class: "hover:underline" %> ·
        Started <%= @deployment.created_at.strftime("%b %d, %Y at %H:%M") %>
        <% if @deployment.user %>
          · by <%= @deployment.user.email %>
        <% end %>
      </p>
    </div>
    <div class="flex items-center gap-2">
      <% if @deployment.in_progress? %>
        <span class="inline-flex items-center gap-2 rounded-lg bg-amber-100 px-4 py-2 text-sm font-medium text-amber-700">
          <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
          In Progress
        </span>
      <% end %>
      <%= link_to "Back to App", app_path(@app), class: "inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
    </div>
  </div>

  <div class="mt-8 grid gap-6 lg:grid-cols-4">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Status</div>
      <div class="mt-2"><span class="<%= status_badge(@deployment.status) %>"><%= @deployment.status %></span></div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Duration</div>
      <div class="mt-2 text-xl font-semibold text-slate-900"><%= @deployment.formatted_duration %></div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Started</div>
      <div class="mt-2 text-sm text-slate-900"><%= @deployment.started_at&.strftime("%H:%M:%S") || "—" %></div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Completed</div>
      <div class="mt-2 text-sm text-slate-900"><%= @deployment.completed_at&.strftime("%H:%M:%S") || "—" %></div>
    </div>
  </div>

  <div class="mt-8 rounded-2xl border border-slate-200 bg-slate-900 shadow-sm overflow-hidden">
    <div class="p-4 border-b border-slate-700 flex items-center justify-between">
      <h3 class="text-sm font-semibold text-white">Deployment Log</h3>
      <% if @deployment.in_progress? %>
        <span id="deploy-live-indicator" class="text-xs text-slate-400">Live streaming...</span>
      <% end %>
    </div>
    <div id="deploy-log-container" class="p-4 max-h-[600px] overflow-y-auto">
      <pre id="deploy-log" class="text-sm text-slate-300 font-mono whitespace-pre-wrap"><%= @deployment.log %></pre>
    </div>
  </div>

  <% if @deployment.in_progress? %>
    <script>
    (function() {
      const logEl = document.getElementById("deploy-log");
      const container = document.getElementById("deploy-log-container");
      const indicator = document.getElementById("deploy-live-indicator");

      const consumer = ActionCable.createConsumer();
      const sub = consumer.subscriptions.create(
        { channel: "DeployChannel", deployment_id: <%= @deployment.id %> },
        {
          received(data) {
            if (data.type === "log") {
              logEl.textContent += data.line;
              container.scrollTop = container.scrollHeight;
            }

            if (data.type === "status" && (data.status === "succeeded" || data.status === "failed")) {
              if (indicator) indicator.textContent = "Completed";
              sub.unsubscribe();
              setTimeout(function() { window.location.reload(); }, 1000);
            }
          },

          disconnected() {
            if (indicator) indicator.textContent = "Disconnected — refreshing...";
            setTimeout(function() { window.location.reload(); }, 3000);
          }
        }
      );
    })();
    </script>
  <% end %>
</section>
