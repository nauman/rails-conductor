<% content_for :title, "MCP Tokens · Conductor" %>

<section class="max-w-3xl mx-auto px-4 py-10">
  <div>
    <h1 class="font-display text-2xl text-ink tracking-display">MCP Tokens</h1>
    <p class="mt-1 text-sm text-muted">Per-user tokens scoped to <strong><%= current_organization.name %></strong>. Use one as the bearer token for an agent (Claude Desktop, Cursor) to deploy this org's apps over MCP. See the <%= link_to "MCP guide", "/docs/mcp", class: "text-primary underline" %>.</p>
  </div>

  <% if @new_token %>
    <div class="mt-6 rounded-large border border-primary/30 bg-primary-tint p-5">
      <div class="text-2xs font-semibold uppercase tracking-label text-primary">New token — copy it now, it won't be shown again</div>
      <code class="mt-2 block font-mono text-xs bg-surface rounded-card px-3 py-2 break-all"><%= @new_token %></code>
    </div>
  <% end %>

  <div class="mt-6 rounded-large border border-border bg-surface p-6 shadow-soft">
    <h2 class="text-sm font-semibold text-ink">Create a token</h2>
    <%= form_with url: mcp_tokens_path, method: :post, class: "mt-4 flex flex-wrap items-end gap-3" do %>
      <div class="flex-1 min-w-[180px]">
        <label class="block text-2xs font-semibold uppercase tracking-label text-muted">Name</label>
        <input type="text" name="name" placeholder="claude-desktop" class="mt-1 block w-full rounded-control border-border-strong text-sm focus:border-primary focus:ring-primary" />
      </div>
      <div>
        <label class="block text-2xs font-semibold uppercase tracking-label text-muted">Scope</label>
        <select name="scope" class="mt-1 block rounded-control border-border-strong text-sm focus:border-primary focus:ring-primary">
          <option value="deploy">deploy (full)</option>
          <option value="read">read-only</option>
        </select>
      </div>
      <%= submit_tag "Create token", class: "rounded-control bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-strong cursor-pointer" %>
    <% end %>
  </div>

  <div class="mt-6 rounded-large border border-border bg-surface shadow-soft overflow-hidden">
    <table class="min-w-full">
      <thead class="bg-fill">
        <tr class="text-2xs font-semibold uppercase tracking-label text-muted">
          <th class="px-6 py-3 text-left">Name</th>
          <th class="px-6 py-3 text-left">Scope</th>
          <th class="px-6 py-3 text-left">Last used</th>
          <th class="px-6 py-3 text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <% @tokens.each do |t| %>
          <tr>
            <td class="px-6 py-4 text-sm font-medium text-ink"><%= t.name %></td>
            <td class="px-6 py-4"><span class="inline-flex items-center rounded-pill px-2.5 py-1 text-2xs font-semibold uppercase tracking-label <%= t.read_only? ? 'bg-info-tint text-info' : 'bg-primary-tint text-primary' %>"><%= t.scope %></span></td>
            <td class="px-6 py-4 text-sm text-muted"><%= t.last_used_at ? "#{time_ago_in_words(t.last_used_at)} ago" : "never" %></td>
            <td class="px-6 py-4 text-right">
              <%= button_to "Revoke", mcp_token_path(t), method: :delete, data: { turbo_confirm: "Revoke this token?" }, class: "text-2xs font-semibold uppercase tracking-label text-danger hover:text-danger-deep" %>
            </td>
          </tr>
        <% end %>
        <% if @tokens.empty? %>
          <tr><td colspan="4" class="px-6 py-10 text-center text-sm text-muted">No tokens yet. Create one above for your agent.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
