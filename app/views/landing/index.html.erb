<div class="mx-auto max-w-5xl px-6">
  <!-- Hero -->
  <section class="py-20 text-center">
    <div class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-large bg-primary font-display text-3xl text-white">C</div>
    <p class="text-2xs font-semibold uppercase tracking-label text-faint">Self-hosted Ruby on Rails ops</p>
    <h1 class="mt-3 font-display text-5xl text-ink tracking-display sm:text-6xl">
      The control plane for<br>self-hosted Ruby on Rails
    </h1>
    <p class="mx-auto mt-5 max-w-2xl text-lg text-muted">
      Conductor runs, monitors, and maintains your <strong class="text-body">Ruby on Rails</strong> apps across your own servers —
      deploys, routing, Postgres, backups, and security — one place instead of five dashboards and a pile of SSH.
    </p>
    <div class="mt-8 flex items-center justify-center gap-3">
      <%= link_to "Sign in", user_sign_in_path, class: "rounded-md bg-primary px-5 py-2.5 text-sm font-medium text-white hover:bg-primary" %>
      <%= link_to "Docs", "/docs", class: "rounded-md border border-border-strong px-5 py-2.5 text-sm font-medium text-body hover:bg-fill" %>
      <%= link_to "View on GitHub", "https://github.com/nauman/rails-conductor", class: "rounded-md border border-border-strong px-5 py-2.5 text-sm font-medium text-body hover:bg-fill" %>
    </div>
    <p class="mt-3 text-xs text-faint">Source-available · run it on your own infrastructure</p>
  </section>

  <!-- Pillars -->
  <section class="grid gap-5 pb-20 sm:grid-cols-2 lg:grid-cols-3">
    <% [
      ["Fleet control", "See every server and app — health, last deploy, and issues — at a glance."],
      ["Deploy your way", "Docker/Kamal and native Puma/Caddy under one control plane."],
      ["Routing & edge", "Manage Caddy routes and domains with live TLS."],
      ["Databases", "Hatchbox-style Postgres: a database + role per app, from the UI."],
      ["Backups & data", "Scheduled database backups to S3/R2."],
      ["Maintenance", "Hardening, auto-updates, and drift checks across the fleet."]
    ].each do |title, body| %>
      <div class="rounded-large border border-border bg-surface p-5 shadow-soft">
        <h3 class="text-sm font-semibold text-ink"><%= title %></h3>
        <p class="mt-1 text-sm text-muted"><%= body %></p>
      </div>
    <% end %>
  </section>
</div>
