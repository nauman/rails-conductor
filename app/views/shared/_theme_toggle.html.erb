<div class="inline-flex items-center" data-controller="theme">
  <input
    type="checkbox"
    id="rui-theme-toggle"
    class="sr-only"
    data-theme-target="checkbox"
    data-action="change->theme#toggle"
    aria-label="Toggle dark mode"
  >

  <label
    for="rui-theme-toggle"
    class="
      rui-theme-toggle relative inline-flex items-center justify-center w-14
      h-7 cursor-pointer rounded-full bg-zinc-200 dark:bg-zinc-700
      transition-colors duration-200
    "
    role="button"
    tabindex="0"
    data-action="dblclick->theme#resetToAuto"
    aria-label="Dark mode toggle (double-click to follow system preference)"
  >
    <span
      class="
        rui-theme-toggle__thumb absolute left-1 w-5 h-5 bg-white
        dark:bg-zinc-900 rounded-full shadow-md transition-transform
        duration-200 flex items-center justify-center
      "
    >
      <svg
        class="rui-theme-toggle__sun w-3 h-3 text-yellow-500"
        fill="currentColor"
        viewBox="0 0 20 20"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
          clip-rule="evenodd"
        />
      </svg>

      <svg
        class="rui-theme-toggle__moon w-3 h-3 text-zinc-600 hidden"
        fill="currentColor"
        viewBox="0 0 20 20"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
        />
      </svg>
    </span>
  </label>
</div>
