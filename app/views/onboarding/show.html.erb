<div class="mx-auto max-w-md py-12">
  <div class="rounded-large border border-border bg-surface p-8 shadow-soft">
    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-card bg-primary text-lg font-bold text-white">C</div>
      <h1 class="font-display text-xl text-ink">Welcome to Conductor</h1>
      <p class="mt-1 text-sm text-muted">
        Your control plane for self-hosted Rails. First, name your organization —
        it's your workspace for servers, apps, and backups.
      </p>
    </div>

    <%= form_with model: @organization, url: onboarding_path, method: :patch, class: "mt-6 space-y-4" do |f| %>
      <% if @organization.errors.any? %>
        <%= rui_alert(type: :danger) do %>
          <%= @organization.errors.full_messages.to_sentence %>
        <% end %>
      <% end %>

      <div class="text-left">
        <%= f.label :name, "Organization name", class: "block text-sm font-medium text-body" %>
        <%= f.text_field :name, autofocus: true, placeholder: "e.g. pavelabs",
              class: "mt-1 block w-full rounded-lg border-border-strong shadow-soft focus:border-primary-tint0 focus:ring-primary-tint0 sm:text-sm" %>
        <p class="mt-1 text-xs text-faint">You can rename this anytime in settings.</p>
      </div>

      <%= f.submit "Continue", class: "w-full cursor-pointer rounded-md bg-primary px-4 py-2.5 text-sm font-medium text-white hover:bg-primary" %>
    <% end %>
  </div>
</div>
