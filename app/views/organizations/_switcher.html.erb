<% if current_organization %>
  <% if current_user.organizations.many? %>
    <details class="relative">
      <summary class="cursor-pointer list-none px-3 py-1.5 rounded-full hover:bg-slate-100">
        <%= current_organization.name %> <span class="text-slate-400">&#9662;</span>
      </summary>
      <div class="absolute right-0 mt-1 w-52 rounded-lg border border-slate-200 bg-white p-1 shadow-lg z-40">
        <% current_user.organizations.order(:name).each do |org| %>
          <%= button_to org.name, switch_organization_path(org),
                class: "block w-full text-left px-3 py-1.5 rounded text-sm #{org.id == current_organization.id ? 'bg-slate-900 text-white' : 'hover:bg-slate-100'}" %>
        <% end %>
      </div>
    </details>
  <% else %>
    <span class="px-3 py-1.5 text-xs text-slate-500"><%= current_organization.name %></span>
  <% end %>
<% end %>
