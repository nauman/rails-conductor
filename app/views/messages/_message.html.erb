<div id="<%= message.dom_id %>" class="flex <%= message.user? ? 'justify-end' : 'justify-start' %>">
  <div class="max-w-[80%]">
    <% if message.user? %>
      <div class="bg-ink text-white px-4 py-3 rounded-large rounded-br-sm text-sm leading-relaxed">
        <%= message.content %>
      </div>
    <% elsif message.pending? || message.streaming? %>
      <div class="bg-surface border border-border px-4 py-3 rounded-large rounded-bl-sm">
        <div class="flex items-center gap-2 text-faint text-sm">
          <span class="flex gap-1">
            <span class="w-1.5 h-1.5 bg-faint rounded-full animate-bounce" style="animation-delay: 0ms"></span>
            <span class="w-1.5 h-1.5 bg-faint rounded-full animate-bounce" style="animation-delay: 150ms"></span>
            <span class="w-1.5 h-1.5 bg-faint rounded-full animate-bounce" style="animation-delay: 300ms"></span>
          </span>
          <span>Conductor is thinking…</span>
        </div>
      </div>
    <% elsif message.error? %>
      <div class="bg-danger-tint border border-danger/30 text-danger-deep px-4 py-3 rounded-large rounded-bl-sm text-sm">
        <%= message.content %>
      </div>
    <% else %>
      <div class="bg-surface border border-border px-4 py-3 rounded-large rounded-bl-sm text-sm leading-relaxed text-ink prose prose-sm max-w-none">
        <%= simple_format(message.content.to_s) %>
      </div>
      <% if message.tool_executions.any? %>
        <div class="mt-2 space-y-1">
          <% message.tool_executions.each do |exec| %>
            <div class="flex items-center gap-2 text-xs text-muted px-1">
              <% if exec.success? %>
                <span class="text-primary-tint0">✓</span>
              <% elsif exec.failed? %>
                <span class="text-danger-tint0">✗</span>
              <% else %>
                <span class="text-faint">…</span>
              <% end %>
              <span class="font-mono"><%= exec.tool_name %></span>
              <% if exec.duration %>
                <span class="text-faint">(<%= exec.duration %>s)</span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
