<% content_for :title, "Servers · Conductor" %>

<section class="max-w-7xl mx-auto px-4 py-10">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="font-display text-2xl text-ink tracking-display">Servers</h1>
      <p class="mt-1 text-sm text-muted">Manage your VM fleet.</p>
    </div>
    <%= link_to new_server_path, class: "inline-flex items-center gap-2 rounded-lg bg-ink px-4 py-2 text-sm font-medium text-white hover:bg-body" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Add Server
    <% end %>
  </div>

  <% if @servers.any? %>
    <div class="mt-6 grid gap-4 lg:grid-cols-3">
      <% @servers.each do |server| %>
        <div class="rounded-large border border-border bg-surface p-5 shadow-soft">
          <div class="flex items-center justify-between">
            <div>
              <div class="text-sm font-semibold text-ink"><%= server.name %></div>
              <div class="text-xs text-muted"><%= server.region || server.provider || "—" %></div>
            </div>
            <span class="<%= status_badge(server.status) %>"><%= server.status %></span>
          </div>
          <div class="mt-4 grid grid-cols-2 gap-3 text-xs text-muted">
            <div class="rounded-lg bg-fill p-3">
              <div class="uppercase tracking-wide text-faint">CPU</div>
              <div class="mt-1 text-sm font-semibold text-ink"><%= server.cpu_display %></div>
            </div>
            <div class="rounded-lg bg-fill p-3">
              <div class="uppercase tracking-wide text-faint">Memory</div>
              <div class="mt-1 text-sm font-semibold text-ink"><%= server.formatted_memory %></div>
            </div>
            <div class="rounded-lg bg-fill p-3">
              <div class="uppercase tracking-wide text-faint">Disk</div>
              <div class="mt-1 text-sm font-semibold text-ink"><%= server.disk_display %></div>
            </div>
            <div class="rounded-lg bg-fill p-3">
              <div class="uppercase tracking-wide text-faint">Uptime</div>
              <div class="mt-1 text-sm font-semibold text-ink"><%= server.formatted_uptime %></div>
            </div>
          </div>
          <div class="mt-4 flex items-center gap-2">
            <%= link_to "View", server_path(server), class: "text-xs font-medium text-body hover:text-ink" %>
            <span class="text-faint">·</span>
            <%= link_to "Edit", edit_server_path(server), class: "text-xs font-medium text-body hover:text-ink" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="mt-6 rounded-large border border-border bg-surface p-12 text-center shadow-soft">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-card bg-fill-strong text-xl text-faint">&#128421;</div>
      <h2 class="font-display text-lg text-ink">No servers yet</h2>
      <p class="mx-auto mt-1 max-w-sm text-sm text-muted">
        Conductor manages servers you already own over SSH. Add one to see live health,
        run deploys, and manage routing.
      </p>
      <%= rui_button "Add your first server", url: new_server_path, color: :primary, class: "mt-5" %>
      <p class="mt-3 text-xs text-faint">You'll need an SSH key and the server's IP.</p>
    </div>
  <% end %>
</section>
