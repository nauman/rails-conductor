<% content_for :title, "Servers · Conductor" %>

<section class="max-w-7xl mx-auto px-4 py-10">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900">Servers</h1>
      <p class="mt-1 text-sm text-slate-500">Manage your VM fleet.</p>
    </div>
    <%= link_to new_server_path, class: "inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Add Server
    <% end %>
  </div>

  <% if @servers.any? %>
    <div class="mt-6 grid gap-4 lg:grid-cols-3">
      <% @servers.each do |server| %>
        <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <div class="flex items-center justify-between">
            <div>
              <div class="text-sm font-semibold text-slate-900"><%= server.name %></div>
              <div class="text-xs text-slate-500"><%= server.region || server.provider || "—" %></div>
            </div>
            <span class="<%= status_badge(server.status) %>"><%= server.status %></span>
          </div>
          <div class="mt-4 grid grid-cols-2 gap-3 text-xs text-slate-500">
            <div class="rounded-lg bg-slate-50 p-3">
              <div class="uppercase tracking-wide text-slate-400">CPU</div>
              <div class="mt-1 text-sm font-semibold text-slate-900"><%= server.cpu_display %></div>
            </div>
            <div class="rounded-lg bg-slate-50 p-3">
              <div class="uppercase tracking-wide text-slate-400">Memory</div>
              <div class="mt-1 text-sm font-semibold text-slate-900"><%= server.formatted_memory %></div>
            </div>
            <div class="rounded-lg bg-slate-50 p-3">
              <div class="uppercase tracking-wide text-slate-400">Disk</div>
              <div class="mt-1 text-sm font-semibold text-slate-900"><%= server.disk_display %></div>
            </div>
            <div class="rounded-lg bg-slate-50 p-3">
              <div class="uppercase tracking-wide text-slate-400">Uptime</div>
              <div class="mt-1 text-sm font-semibold text-slate-900"><%= server.formatted_uptime %></div>
            </div>
          </div>
          <div class="mt-4 flex items-center gap-2">
            <%= link_to "View", server_path(server), class: "text-xs font-medium text-slate-600 hover:text-slate-900" %>
            <span class="text-slate-300">·</span>
            <%= link_to "Edit", edit_server_path(server), class: "text-xs font-medium text-slate-600 hover:text-slate-900" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="mt-6 rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-12 text-center">
      <div class="text-sm text-slate-500">No servers yet.</div>
      <%= link_to "Add your first server", new_server_path, class: "mt-2 inline-block text-sm font-medium text-slate-900 hover:underline" %>
    </div>
  <% end %>
</section>
