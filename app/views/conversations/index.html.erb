<% content_for :title, "Conversations — Conductor" %>

<div class="max-w-3xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="font-display text-xl text-ink">Chat</h1>
    <%= button_to "New conversation", conversations_path, method: :post,
        class: "px-4 py-2 bg-ink text-white text-sm font-medium rounded-lg hover:bg-body" %>
  </div>

  <% if @conversations.empty? %>
    <div class="text-center py-16 text-muted">
      <p class="text-sm mb-4">No conversations yet.</p>
      <%= button_to "Start chatting with Conductor", conversations_path, method: :post,
          class: "px-4 py-2 bg-ink text-white text-sm font-medium rounded-lg hover:bg-body" %>
    </div>
  <% else %>
    <div class="space-y-2">
      <% @conversations.each do |convo| %>
        <%= link_to conversation_path(convo), class: "block p-4 bg-surface border border-border rounded-card hover:border-border-strong hover:shadow-soft transition-all" do %>
          <div class="flex items-center justify-between">
            <div class="font-medium text-ink text-sm truncate">
              <%= convo.title.presence || "Untitled conversation" %>
            </div>
            <div class="text-xs text-faint shrink-0 ml-3">
              <%= time_ago_in_words(convo.created_at) %> ago
            </div>
          </div>
          <div class="text-xs text-muted mt-1">
            <%= pluralize(convo.messages.count, 'message') %>
            · <%= convo.status %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
