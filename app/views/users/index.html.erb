<% content_for :title, "Users · Conductor" %>

<section class="max-w-4xl mx-auto px-4 py-10">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="font-display text-2xl text-ink tracking-display">Users</h1>
      <p class="mt-1 text-sm text-muted">Manage who can access Conductor</p>
    </div>
  </div>

  <div class="mt-8 rounded-large border border-border bg-surface shadow-soft overflow-hidden">
    <div class="p-4 border-b border-border bg-fill">
      <h3 class="text-sm font-semibold text-ink">Add User</h3>
      <%= form_tag users_path, method: :post, class: "mt-3 flex items-end gap-3" do %>
        <div class="flex-1">
          <label for="email" class="block text-xs font-medium text-body mb-1">Email</label>
          <input type="email" name="email" id="email" required
                 placeholder="user@example.com"
                 class="block w-full rounded-lg border-border-strong shadow-soft focus:border-primary focus:ring-primary sm:text-sm">
        </div>
        <div class="flex items-center gap-2">
          <input type="checkbox" name="admin" value="1" id="admin_checkbox"
                 class="rounded border-border-strong text-ink focus:ring-primary">
          <label for="admin_checkbox" class="text-sm text-body">Admin</label>
        </div>
        <button type="submit" class="inline-flex items-center rounded-lg bg-ink px-4 py-2 text-sm font-medium text-white hover:bg-body">
          Add User
        </button>
      <% end %>
    </div>

    <table class="min-w-full divide-y divide-border">
      <thead class="bg-fill">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Email</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Role</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-muted">Joined</th>
          <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-muted">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border bg-surface">
        <% @users.each do |user| %>
          <tr>
            <td class="px-4 py-3 text-sm text-ink">
              <%= user.email %>
              <% if user == current_user %>
                <span class="ml-1 text-xs text-faint">(you)</span>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <% if user.admin? %>
                <span class="inline-flex items-center rounded-full bg-warning-tint px-2 py-0.5 text-xs font-medium text-warning">Admin</span>
              <% else %>
                <span class="inline-flex items-center rounded-full bg-fill-strong px-2 py-0.5 text-xs font-medium text-body">Member</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-sm text-muted">
              <%= user.created_at.strftime("%b %d, %Y") %>
            </td>
            <td class="px-4 py-3 text-right text-sm">
              <% if user != current_user %>
                <%= button_to toggle_admin_user_path(user), method: :patch, class: "text-body hover:text-ink mr-3" do %>
                  <%= user.admin? ? "Remove admin" : "Make admin" %>
                <% end %>
                <%= button_to user_path(user), method: :delete,
                    data: { turbo_confirm: "Remove #{user.email}?" },
                    class: "text-danger hover:text-danger-deep" do %>
                  Remove
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
